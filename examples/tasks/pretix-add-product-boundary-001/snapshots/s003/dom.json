                                                <a href=\"/control/event/nexui/nexui-event/checkins/\">\n                                                            Check-in history\n                                                        </a>\n                                                    </li>\n                                                \n                                            </ul>\n                                        \n                                    </li>\n                                \n                                    <li>\n                                        <a href=\"/control/event/nexui/nexui-event/sendmail/\" class=\"has-children\" data-nexui-ref=\"e24\">\n                                            \n                                                \n                                                    <span class=\"fa fa-fw fa-envelope\"></span>\n                                                \n                                            \n                                            Send out emails\n                                        </a>\n                                        \n                                            <a href=\"#\" class=\"arrow\" data-nexui-ref=\"e25\">\n                                                <span class=\"fa arrow\"></span>\n                                            </a>\n                                            <ul class=\"nav nav-second-level collapse\">\n                                                \n                                                    <li>\n                                                        <a href=\"/control/event/nexui/nexui-event/sendmail/\">\n                                                            Send email\n                                                        </a>\n                                                    </li>\n                                                \n                                                    <li>\n                                                        <a href=\"/control/event/nexui/nexui-event/sendmail/rules\">\n                                                            Scheduled emails\n                                                        </a>\n                                                    </li>\n                                                \n                                                    <li>\n                                                        <a href=\"/control/event/nexui/nexui-event/sendmail/history/\">\n                                                            Email history\n                                                        </a>\n                                                    </li>\n                                                \n                                            </ul>\n                                        \n                                    </li>\n                                \n                            \n                        </ul>\n                        \n                    </div>\n                </div>\n            </nav>\n            \n            \n            \n            \n            <div id=\"page-wrapper\" style=\"min-height: 849px;\">\n                <div class=\"container-fluid\">\n                    \n                    \n                    \n                    \n                        <div class=\"alert alert-info\">\n                            <a href=\"/control/global/update/\" data-nexui-ref=\"e26\">\n                                Starting with version 1.2.0, pretix automatically checks for updates in the background. During this check, anonymous data is transmitted to servers operated by pretix' developers. Click on this message to find out more, disable this feature or enter your email address to get notified via email if a new update arrives. This message will disappear once you clicked it.\n                            </a>\n                        </div>\n                    \n                    \n                        <div class=\"alert alert-legal\">\n                            <a href=\"/control/global/license/\" data-nexui-ref=\"e27\">\n                                Click here to do a license compliance check to make sure your usage of pretix is in line with pretix' license.\n                            </a>\n                        </div>\n                    \n                    \n                        <div class=\"alert alert-warning\">\n                            The cronjob component of pretix was not executed in the last hours. Please check that you have completed all installation steps and your cronjob is executed correctly.\n                        </div>\n                    \n\n                    \n\n                    \n\n                    \n    \n        <h1>Create product</h1>\n        <p>You will be able to adjust further settings in the next step.</p>\n    \n    \n    \n    \n\n    \n\n<script type=\"text/javascript\" src=\"/static/pretixcontrol/js/ui/hidequota.cb74897c3b3f.js\"></script>\n\n    <form action=\"\" method=\"post\" class=\"form-horizontal\" enctype=\"multipart/form-data\">\n        <input type=\"hidden\" name=\"csrfmiddlewaretoken\" value=\"3OL3dyrVGrjuF1Q7pMH5T2Mqg0AQ660toMGX4zVsr3Jnx78ZeGaECjA3x9kx6Hqc\">\n        <fieldset>\n            <legend>General information</legend>\n            <div class=\"form-group\" role=\"group\" aria-labelledby=\"legend-name\"><label class=\"col-md-3 control-label\" id=\"legend-name\">Item name</label><div class=\"col-md-9\"><div class=\"i18n-form-group i18n-form-single-language\" id=\"id_name\"><input type=\"text\" name=\"name_0\" lang=\"en\" dir=\"ltr\" class=\"form-control\" title=\"English\" id=\"id_name_0\" placeholder=\"English\" data-nexui-ref=\"e28\"></div></div></div>\n            <div class=\"internal-name-wrapper\">\n                <div class=\"form-group\" style=\"display: none;\"><label class=\"col-md-3 control-label\" for=\"id_internal_name\">Internal name<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><input type=\"text\" name=\"internal_name\" maxlength=\"255\" class=\"form-control\" title=\"If you set this, this will be used instead of the public name in the backend.\" aria-describedby=\"id_internal_name_helptext\" id=\"id_internal_name\">\n\n    <div class=\"help-block\">If you set this, this will be used instead of the public name in the backend.</div>\n\n</div></div>\n            <div class=\"form-group\"><div class=\"col-md-9 col-md-offset-3\"><div class=\"help-block\"><a href=\"#\" data-nexui-ref=\"e29\">Use a different name internally</a></div></div></div></div>\n            <div class=\"form-group\"><label class=\"col-md-3 control-label\" for=\"id_copy_from\">Copy product information<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><select name=\"copy_from\" class=\"form-control\" title=\"\" id=\"id_copy_from\" data-nexui-ref=\"e30\">\n  <option value=\"\" selected=\"\">Do not copy</option>\n\n  <option value=\"1\">General Admission</option>\n\n</select></div></div>\n\n            <div class=\"form-group\">\n                <label class=\"col-md-3 control-label\">Product type</label>\n                <div class=\"col-md-9\">\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"on\" name=\"admission\" checked=\"\" id=\"admission_on\" data-nexui-ref=\"e31\">\n                            <span class=\"fa fa-fw fa-user\"></span>\n                            <strong>Admission product</strong><br>\n                            <div class=\"help-block\">\n                                Every purchase of this product represents one person who is allowed to enter your event. By default, we will only offer ticket downloads for these products.\n                            </div>\n                            <div class=\"help-block\">\n                                Only purchases of such products will be considered \"attendees\" for most statistical purposes or within some plugins.\n                            </div>\n                            <div class=\"help-block\">\n                                This option should be set for most things that you would call a \"ticket\". For product add-ons or bundles, this should be set on the main ticket, except if the add-on products or bundled products represent additional people (e.g. group bundles).\n                            </div>\n                        </label>\n                    </div>\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"\" name=\"admission\" data-nexui-ref=\"e32\">\n                            <span class=\"fa fa-fw fa-cube\"></span>\n                            <strong>Non-admission product</strong>\n                            <div class=\"help-block\">\n                                A product that does not represent a person. By default, we will not offer ticket downloads (but you can still enable ticket downloads in event settings or product settings).\n                            </div>\n                            <div class=\"help-block\">\n                                Examples: Merchandise, donations, gift cards, add-ons to a main ticket.\n                            </div>\n                        </label>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"form-group\" data-display-dependency=\"#admission_on\">\n                <label class=\"col-md-3 control-label\">Personalization</label>\n                <div class=\"col-md-9\">\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"on\" name=\"personalized\" checked=\"\" data-nexui-ref=\"e33\">\n                            <span class=\"fa fa-fw fa-id-card-o\"></span>\n                            <strong>Personalized ticket</strong><br>\n                            <div class=\"help-block\">\n                                When this ticket is purchased, the system will ask for a name or other details according to your event settings.\n                                \n                            </div>\n                        </label>\n                    </div>\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"\" name=\"personalized\" data-nexui-ref=\"e34\">\n                            <span class=\"fa fa-fw fa-circle-o\"></span>\n                            <strong>Non-personalized ticket</strong>\n                            <div class=\"help-block\">\n                                The system will not ask for a name or other attendee details. This only affects system-provided fields, you can still add your own questions.\n                            </div>\n                        </label>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"form-group\"><label class=\"col-md-3 control-label\" for=\"id_category\">Category<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><select name=\"category\" data-model-select2=\"generic\" data-select2-url=\"/control/event/nexui/nexui-event/categories/select2\" data-placeholder=\"No category\" class=\"form-control select2-hidden-accessible\" title=\"If you have many products, you can optionally sort them into categories to keep things organized.\" aria-describedby=\"id_category_helptext\" id=\"id_category\" data-select2-id=\"select2-data-id_category\" tabindex=\"-1\" aria-hidden=\"true\" data-nexui-ref=\"e35\">\n</select><span class=\"select2 select2-container select2-container--bootstrap\" dir=\"ltr\" data-select2-id=\"select2-data-1-gpzd\" style=\"width: 100%;\"><span class=\"selection\"><span class=\"select2-selection select2-selection--single\" role=\"combobox\" aria-haspopup=\"true\" aria-expanded=\"false\" title=\"If you have many products, you can optionally sort them into categories to keep things organized.\" tabindex=\"0\" aria-disabled=\"false\" aria-labelledby=\"select2-id_category-container\" data-nexui-ref=\"e36\"><span class=\"select2-selection__rendered\" id=\"select2-id_category-container\" role=\"textbox\" aria-readonly=\"true\" data-nexui-ref=\"e37\"><span class=\"select2-selection__placeholder\">No category</span></span><span class=\"select2-selection__arrow\" role=\"presentation\"><b role=\"presentation\"></b></span></span></span><span class=\"dropdown-wrapper\" aria-hidden=\"true\"></span></span>\n<noscript>\n    <div class=\"alert alert-danger\">\n        Please enable JavaScript in your browser.\n    </div>\n</noscript>\n\n    <div class=\"help-block\">If you have many products, you can optionally sort them into categories to keep things organized.</div>\n\n</div></div>\n\n            <div class=\"form-group\">\n                <label class=\"col-md-3 control-label\">Product variations</label>\n                <div class=\"col-md-9\">\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"\" name=\"has_variations\" checked=\"\" data-nexui-ref=\"e38\">\n                            <span class=\"fa fa-fw fa-square\"></span>\n                            <strong>Product without variations</strong><br>\n                        </label>\n                    </div>\n                    <div class=\"big-radio radio\">\n                        <label>\n                            <input type=\"radio\" value=\"on\" name=\"has_variations\" data-nexui-ref=\"e39\">\n                            <span class=\"fa fa-fw fa-th-large\"></span>\n                            <strong>Product with multiple variations</strong>\n                            <div class=\"help-block\">\n                                This product exists in multiple variations which are different in either their name, price, quota, or description. All other settings need to be the same.\n                            </div>\n                            <div class=\"help-block\">\n                                Examples: Ticket category with variations for \"full price\" and \"reduced\", merchandise with variations for different sizes, workshop add-on with variations for simultaneous workshops.\n                            </div>\n                        </label>\n                    </div>\n                </div>\n            </div>\n\n            \n\n        </fieldset>\n        \n            <fieldset>\n                <legend>Quota settings</legend>\n                <div class=\"form-group\" role=\"group\" aria-labelledby=\"legend-quota_option\"><label class=\"col-md-3 control-label\" id=\"legend-quota_option\">Quota options<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><div id=\"id_quota_option\"> <div class=\"radio\"><label for=\"id_quota_option_0\"><input type=\"radio\" name=\"quota_option\" value=\"none\" class=\"\" title=\"\" id=\"id_quota_option_0\" checked=\"\" data-nexui-ref=\"e40\">\n Do not add to a quota now</label>\n\n</div> <div class=\"radio\"><label for=\"id_quota_option_1\"><input type=\"radio\" name=\"quota_option\" value=\"existing\" class=\"\" title=\"\" id=\"id_quota_option_1\" data-nexui-ref=\"e41\">\n Add product to an existing quota</label>\n\n</div> <div class=\"radio\"><label for=\"id_quota_option_2\"><input type=\"radio\" name=\"quota_option\" value=\"new\" class=\"\" title=\"\" id=\"id_quota_option_2\" data-nexui-ref=\"e42\">\n Create a new quota for this product</label>\n\n</div>\n</div></div></div>\n                <div id=\"existing-quota-group\">\n                    <div class=\"form-group\" style=\"display: none;\"><label class=\"col-md-3 control-label\" for=\"id_quota_add_existing\">Add to existing quota<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><select name=\"quota_add_existing\" class=\"form-control\" title=\"\" id=\"id_quota_add_existing\">\n  <option value=\"\" selected=\"\">---------</option>\n\n  <option value=\"1\">General Admission</option>\n\n</select></div></div>\n                </div>\n                <div id=\"new-quota-group\">\n                    <div class=\"form-group\" style=\"display: none;\"><label class=\"col-md-3 control-label\" for=\"id_quota_add_new_name\">Name<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><input type=\"text\" name=\"quota_add_new_name\" placeholder=\"New quota name\" maxlength=\"200\" class=\"form-control\" title=\"\" id=\"id_quota_add_new_name\"></div></div>\n                    <div class=\"form-group\" style=\"display: none;\"><label class=\"col-md-3 control-label\" for=\"id_quota_add_new_size\">Size<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><input type=\"text\" name=\"quota_add_new_size\" placeholder=\"Number of tickets\" class=\"form-control\" title=\"Leave empty for an unlimited number of tickets.\" aria-describedby=\"id_quota_add_new_size_helptext\" id=\"id_quota_add_new_size\">\n\n    <div class=\"help-block\">Leave empty for an unlimited number of tickets.</div>\n\n</div></div>\n                </div>\n            </fieldset>\n        \n        <fieldset>\n            <legend>Price settings</legend>\n            <div class=\"form-group\"><label class=\"col-md-3 control-label\" for=\"id_default_price\">Default price</label><div class=\"col-md-9\"><input type=\"text\" name=\"default_price\" class=\"form-control\" title=\"If this product has multiple variations, you can set different prices for each of the variations. If a variation does not have a special price or if you do not have variations, this price will be used.\" required=\"\" aria-describedby=\"id_default_price_helptext\" id=\"id_default_price\" data-nexui-ref=\"e43\">\n\n    <div class=\"help-block\">If this product has multiple variations, you can set different prices for each of the variations. If a variation does not have a special price or if you do not have variations, this price will be used.</div>\n\n</div></div>\n            <div class=\"form-group\"><label class=\"col-md-3 control-label\" for=\"id_tax_rule\">Sales tax<br><span class=\"optional\">Optional</span></label><div class=\"col-md-9\"><select name=\"tax_rule\" class=\"form-control\" title=\"\" id=\"id_tax_rule\" data-nexui-ref=\"e44\">\n  <option value=\"\" selected=\"\">No taxation</option>\n\n</select></div></div>\n        </fieldset>\n        <div class=\"form-group submit-group\">\n            <button type=\"submit\" class=\"btn btn-primary btn-save\" data-nexui-ref=\"e45\">\n                Save and continue with more settings\n            </button>\n        </div>\n    </form>\n\n\n                    <footer>\n                        \n                            <span class=\"fa fa-globe\"></span>\n                            Times displayed in UTC ·\n                        \n                        <a href=\"/redirect/?url=https%3A//pretix.eu%3AeuTro54DJwl5DGiV43laun1tVVNUnqO6hGViSZAJ4T0\" target=\"_blank\" rel=\"noopener\" data-nexui-ref=\"e46\">ticketing powered by pretix</a> \n                        \n                    </footer>\n                </div>\n            </div>\n        </div>\n        <div id=\"ajaxerr\" class=\"modal-wrapper\" hidden=\"\">\n        </div>\n        \n    <dialog id=\"loadingmodal\" class=\"modal-card\" aria-labelledby=\"loadingmodal-title\" aria-describedby=\"loadingmodal-description\" closedby=\"none\">\n        <form method=\"dialog\" class=\"modal-card-inner form-horizontal\">\n            <div class=\"modal-card-icon\"><span class=\"fa fa-cog rotating\" aria-hidden=\"true\"></span></div>\n            <div class=\"modal-card-content\">\n                <h2 id=\"loadingmodal-title\" class=\"modal-card-title h3\"></h2>\n                <p id=\"loadingmodal-description\" class=\"modal-card-description\"></p>\n                \n            <p class=\"status\">If this takes longer than a few minutes, please contact us.</p>\n            <div class=\"progress\">\n                <div class=\"progress-bar progress-bar-success\">\n                </div>\n            </div>\n            <div class=\"steps\">\n            </div>\n        \n            </div>\n        </form>\n    </dialog>\n    \n\t\n\n<div id=\"lightboxOverlay\" class=\"lightboxOverlay\" style=\"display: none;\"></div><div id=\"lightbox\" class=\"lightbox\" role=\"dialog\" aria-labelledby=\"lightboxLabel\" aria-modal=\"true\" style=\"display: none;\"><div class=\"lb-outerContainer\"><div class=\"lb-container\"><img class=\"lb-image\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAP///wAAACH5BAEAAAAALAAAAAABAAEAAAICRAEAOw==\"><div class=\"lb-nav\"><a class=\"lb-prev\" href=\"\"></a><a class=\"lb-next\" href=\"\"></a></div><div class=\"lb-loader\"><a class=\"lb-cancel\"></a></div></div></div><div class=\"lb-dataContainer\"><div class=\"lb-data\"><div class=\"lb-details\" id=\"lightboxLabel\"><span class=\"lb-caption\"></span><span class=\"lb-number\"></span></div><div class=\"lb-closeContainer\"><button aria-label=\"close\" class=\"lb-close\"></button></div></div></div></div></body></html>"
