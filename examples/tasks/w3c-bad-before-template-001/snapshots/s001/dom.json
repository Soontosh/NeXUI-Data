{
  "url": "https://www.w3.org/WAI/demos/bad/before/template.html",
  "title": "Welcome to CityLights! [Inaccessible Template Page]",
  "html": "<html><head>\n<title>Welcome to CityLights! [Inaccessible Template Page]</title>    <style>\n      #main * {\n        color: #000000;\n        font: normal 15px \"Times New Roman\", Times, serif;\n        text-decoration: none;\n      }\n      #main p{\n        margin: 6px 0;\n      }\n      #main .headline {\n        margin-top: 0px;\n        color: #41545d;\n        font: 24px verdana;\n        font-family: impact;\n        text-decoration: none;\n      }\n    </style>\n    <link href=\"../css/meta.css\" rel=\"stylesheet\" type=\"text/css\">\n    <script type=\"text/javascript\" async=\"\" defer=\"\" src=\"//www.w3.org/analytics/piwik/piwik.js\"></script><script type=\"text/javascript\">\n      function ChangeColor(id, colour){\n        document.getElementById(id).style.backgroundColor=colour;\n      }\n      function switchImage(imgName, imgSrc){\n        if (document.images){\n          if (imgSrc != \"none\"){\n              document.images[imgName].src = imgSrc;\n          }\n        }\n      }\n    </script>\n    <noscript><B><FONT COLOR=RED>This page uses scripts!!!</FONT></B></noscript>\n    <script src=\"../js/onload.js\" type=\"text/javascript\"></script>\n  </head>\n  <body text=\"#000000\" bgcolor=\"#D7D7CD\" leftmargin=\"0px\" topmargin=\"0px\" marginwidth=\"0px\" marginheight=\"0px\" link=\"#226C8E\" vlink=\"#226C8E\" alink=\"#226C8E\">\n    <div id=\"meta-header\">\n      <p id=\"skipnav\"><a href=\"#page\" data-nexui-ref=\"e1\">Skip to inaccessible demo page</a></p>\n      <p id=\"logos\"><a href=\"https://www.w3.org/\" title=\"W3C Home\" data-nexui-ref=\"e2\"><img alt=\"W3C logo\" src=\"../img/w3c.png\" height=\"48\" width=\"72\"></a><a href=\"https://www.w3.org/WAI/\" title=\"WAI Home\" data-nexui-ref=\"e3\"><img alt=\"Web Accessibility Initiative (WAI) logo\" src=\"../img/wai.png\" height=\"48\"></a></p>\n      <h1><span class=\"subhead\">Inaccessible Template Page</span><span class=\"hidden\"> -</span> Before and After Demonstration</h1>\n      <p class=\"subline\">Improving a Web site using Web Content Accessibility Guidelines (WCAG) 2.0</p>\n      <div id=\"mnav\" class=\"inaccessible\">\n        <ul>\n          <li class=\"first\"><a href=\"../Overview.html\" data-nexui-ref=\"e4\">Overview</a></li>\n          <li class=\"first\"><a href=\"home.html\" data-nexui-ref=\"e5\">Home</a></li>\n          <li><a href=\"news.html\" data-nexui-ref=\"e6\">News</a></li>\n          <li><a href=\"tickets.html\" data-nexui-ref=\"e7\">Tickets</a></li>\n          <li><a href=\"survey.html\" data-nexui-ref=\"e8\">Survey</a></li>\n          <li class=\"current\"><span class=\"hidden\">Current location: </span>Template\n            <div class=\"subnav\"><ul>\n              <li class=\"inaccessible\"><strong>Inaccessible:</strong><a class=\"page current\"><span class=\"hidden\">Inaccessible </span>Template</a><a href=\"./reports/template.html\" class=\"report\" data-nexui-ref=\"e9\"><span class=\"hidden\">Inaccessible Template </span> Report</a></li>\n              <li class=\"accessible\"><strong>Accessible:</strong><a href=\"../after/template.html\" class=\"page\" data-nexui-ref=\"e10\"><span class=\"hidden\">Accessible </span>Template</a><a href=\"../after/reports/template.html\" class=\"report\" data-nexui-ref=\"e11\"><span class=\"hidden\">Accessible Template </span> Report</a></li>\n            </ul><a href=\"./annotated/template.html\" class=\"annotoggle\" data-nexui-ref=\"e12\">Show <br>Annotations</a></div>\n          </li>\n        </ul>\n      </div>\n    </div>\n    <div id=\"page\">\n    <p class=\"skip\" id=\"startcontent\">Demo starts here</p>\n    <table width=\"100%\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"#D7D7CD\"><tbody><tr valign=\"MIDDLE\"><td width=\"100%\" align=\"CENTER\">\n    <table width=\"800px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"WHITE\">\n      <tbody><tr height=\"10px\">\n        <td width=\"10px\" background=\"./img/border_left_top.gif\"><img src=\"./img/border_left_top.gif\" width=\"10px\" height=\"10px\"></td>\n        <td width=\"780px\" background=\"./img/border_top.gif\"><img src=\"./img/border_top.gif\" height=\"10px\"></td>\n        <td width=\"10px\" background=\"./img/border_right_top.gif\"><img src=\"./img/border_right_top.gif\" width=\"10px\" height=\"10px\"></td>\n      </tr>\n      <tr>\n        <td width=\"10px\" background=\"./img/border_left.gif\"><img src=\"./img/border_left.gif\" width=\"10px\"></td>\n        <td width=\"780px\" align=\"CENTER\">\n    <table width=\"780px\" height=\"144px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"WHITE\">\n      <tbody><tr height=\"86px\">\n        <td width=\"443px\" background=\"./img/top_logo_next.gif\" valign=\"MIDDLE\"><div><a href=\"home.html\" data-nexui-ref=\"e13\"><img src=\"./img/top_logo.gif\" width=\"443px\" height=\"86px\" alt=\"Red dot with a white letter 'C' that symbolizes a moon crescent as well as the sun. This logo is followed by a black banner that says 'CITYLIGHTS' which is the name of this online portal. Finally, the slogan of the portal, 'your access to the city', follows in a turquoise green handwriting style and with a slight slant across the top banner.\"></a></div></td>\n        <td width=\"24px\" valign=\"MIDDLE\"><img src=\"./img/top_logo_next_end.gif\" width=\"24px\" height=\"86px\"></td>\n        <td width=\"128px\" valign=\"MIDDLE\"><img src=\"./img/top_weather.gif\" width=\"128px\" height=\"86px\"></td>\n        <td width=\"22px\" valign=\"MIDDLE\"><img src=\"./img/top_logo_next_start.gif\" width=\"22px\" height=\"86px\"></td>\n        <td width=\"163px\" background=\"./img/top_logo_next.gif\" align=\"CENTER\" valign=\"MIDDLE\">\n          <select onchange=\"location.href = this.value;\" data-nexui-ref=\"e14\">\n            <option selected=\"\">QUICKMENU ----&gt;\n            </option><option value=\"../offsite.html\">Broadcasting\n            </option><option value=\"../offsite.html\">Education\n            </option><option value=\"../offsite.html\">Electricity\n            </option><option value=\"../offsite.html\">Fire service\n            </option><option value=\"../offsite.html\">Gas service\n            </option><option value=\"../offsite.html\">Health care\n            </option><option value=\"../offsite.html\">Police service\n            </option><option value=\"../offsite.html\">Public Libraries\n            </option><option value=\"../offsite.html\">Social services\n            </option><option value=\"../offsite.html\">Social housing\n            </option><option value=\"../offsite.html\">Telecommunications\n            </option><option value=\"../offsite.html\">Town planning\n            </option><option value=\"../offsite.html\">Transportation\n            </option><option value=\"../offsite.html\">Waste management\n            </option><option value=\"../offsite.html\">Water services\n          </option></select>\n        </td>\n      </tr>\n      <tr height=\"7px\">\n        <td width=\"780px\" background=\"./img/mark.gif\" colspan=\"5\"><img src=\"./img/mark.gif\" width=\"158px\" height=\"7px\"></td>\n      </tr>\n      <tr height=\"25px\">\n        <td colspan=\"5\">\n          <table width=\"780px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\">\n            <tbody><tr height=\"25px\">\n              <td bgcolor=\"#EDEDED\" width=\"380px\"><font color=\"BLACK\" face=\"Verdana\" size=\"2\">&nbsp;&nbsp;<b>Traffic:</b> Construction work on Main Road</font></td>\n              <td bgcolor=\"#EDEDED\" align=\"RIGHT\" id=\"WEATHER\"><font color=\"BLACK\" face=\"Verdana\" size=\"2\"><b>Today:</b>\n                <script language=\"JavaScript\">\n                  var now = new Date();\n                  var days = new Array('Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday');\n                  var months = new Array('January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December');\n                  var date = ((now.getDate()<10) ? \"0\" : \"\")+ now.getDate();\n                  function fourdigits(number)\t{\n                    return (number < 1000) ? number + 1900 : number;\n                  }\n                  today =  days[now.getDay()] + \" \" + date + \" \" + months[now.getMonth()] + \" \" + (fourdigits(now.getYear())) + \", Sunny, 23&deg;C&nbsp;&nbsp;</FONT>\";\n                  document.all.WEATHER.setAttribute(\"BGCOLOR\", \"#EDEDED\", 0);\n                  document.write(today);\n                </script>Thursday 28 May 2026, Sunny, 23°C&nbsp;&nbsp;</font></td>\n            </tr>\n          </tbody></table>\n        </td>\n      </tr>\n      <tr height=\"1px\">\n        <td width=\"780px\" background=\"./img/marker2_w.gif\" colspan=\"5\"><img src=\".img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n      </tr>\n      <tr height=\"25px\">\n        <td colspan=\"5\">&nbsp;</td>\n      </tr>\n    </tbody></table>\n    <table width=\"780px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"WHITE\">\n      <tbody><tr width=\"780px\">\n        <td width=\"155px\" bgcolor=\"#E4E4E4\" valign=\"TOP\">\n          <table width=\"155px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\">\n            <tbody><tr height=\"1px\">\n              <td width=\"155px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n              <td width=\"1px\" background=\"./img/marker2_t.gif\" rowspan=\"9\" valign=\"TOP\"><img src=\"./img/marker2_t.gif\" width=\"1\" height=\"30px\"></td>\n            </tr>\n            <tr height=\"34px\">\n              <td width=\"154px\" bgcolor=\"#EDEDED\" id=\"home\" onmouseover=\"switchImage('nav_home', './img/nav_home2.gif'); ChangeColor('home','#FFF')\" onmouseout=\"switchImage('nav_home', './img/nav_home.gif'); ChangeColor('home','#EDEDED')\"><a href=\"javascript:location.href='home.html';\" onfocus=\"blur();\" data-nexui-ref=\"e15\"><img name=\"nav_home\" src=\"./img/nav_home.gif\" width=\"88\" height=\"27\" hspace=\"15\" border=\"0px\"></a></td>\n            </tr>\n            <tr height=\"1px\">\n              <td width=\"154px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n            </tr>\n            <tr height=\"34px\">\n              <td width=\"154px\" bgcolor=\"#EDEDED\" id=\"news\" onmouseover=\"switchImage('nav_news', './img/nav_news2.gif'); ChangeColor('news','#FFF')\" onmouseout=\"switchImage('nav_news', './img/nav_news.gif'); ChangeColor('news','#EDEDED')\"><a href=\"javascript:location.href='news.html';\" onfocus=\"blur();\" data-nexui-ref=\"e16\"><img src=\"./img/nav_news.gif\" name=\"nav_news\" width=\"90\" height=\"21\" hspace=\"12\" border=\"0px\"></a></td>\n            </tr>\n            <tr height=\"1px\">\n              <td width=\"154px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n            </tr>\n            <tr height=\"34px\">\n              <td width=\"154px\" bgcolor=\"#EDEDED\" id=\"tickets\" onmouseover=\"switchImage('nav_facts', './img/nav_facts2.gif'); ChangeColor('tickets','#FFF')\" onmouseout=\"switchImage('nav_facts', './img/nav_facts.gif'); ChangeColor('tickets','#EDEDED')\"><a href=\"javascript:location.href='tickets.html';\" onfocus=\"blur();\" data-nexui-ref=\"e17\"><img name=\"nav_facts\" src=\"./img/nav_facts.gif\" width=\"105\" height=\"23\" hspace=\"9\" border=\"0px\"></a></td>\n            </tr>\n            <tr height=\"1px\">\n              <td width=\"154px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n            </tr>\n            <tr height=\"34px\">\n              <td width=\"154px\" bgcolor=\"#EDEDED\" id=\"survey\" onmouseover=\"switchImage('nav_survey', './img/nav_survey2.gif'); ChangeColor('survey','#FFF')\" onmouseout=\"switchImage('nav_survey', './img/nav_survey.gif'); ChangeColor('survey','#EDEDED')\"><a href=\"javascript:location.href='survey.html';\" onfocus=\"blur();\" data-nexui-ref=\"e18\"><img src=\"./img/nav_survey.gif\" name=\"nav_survey\" width=\"107\" height=\"32\" hspace=\"8\" border=\"0px\"></a></td>\n            </tr>\n            <tr height=\"1px\">\n              <td width=\"154px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n            </tr>\n          </tbody></table>\n        </td>\n        <td width=\"20px\"><img src=\"./img/blank_5x5.gif\" width=\"20px\" height=\"5px\"></td>\n        <td width=\"434px\" height=\"600px\" valign=\"TOP\" id=\"main\"><div <!--=\"\" ###=\"\" enter=\"\" content=\"\" here=\"\" --=\"\">\n        <p class=\"headline\">Template</p>\n        [CONTENT]\n        </div>\n        </td>\n        <td width=\"20px\"><img src=\"./img/blank_5x5.gif\" width=\"20px\" height=\"5px\"></td>\n        <td width=\"151px\" valign=\"TOP\">\n          <table width=\"151px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\">\n            <tbody><tr height=\"1px\">\n              <td width=\"1px\" background=\"./img/marker2_t.gif\" rowspan=\"11\" valign=\"TOP\"><img src=\"./img/marker2_t.gif\" width=\"1px\" height=\"30px\"></td>\n              <td width=\"151px\" background=\"./img/marker2_w.gif\"><img src=\"./img/marker2_w.gif\" width=\"78px\" height=\"1px\"></td>\n            </tr>\n            <tr height=\"25px\">\n              <td width=\"150px\" bgcolor=\"#A9B8BF\"><font color=\"#41545D\" face=\"Verdana\" size=\"2\">&nbsp;<b>[TITLE]</b></font></td>\n            </tr>\n            <tr height=\"154px\">\n              <td width=\"150px\">[IMAGE]</td>\n            </tr>\n            <tr>\n              <td width=\"150px\">\n                <table width=\"150px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"3px\">\n                  <tbody><tr>\n                    <td><div>[