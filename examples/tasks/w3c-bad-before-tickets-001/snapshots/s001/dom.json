<td>12/2/06</td>\n                    <td>24/3/06</td>\n                  </tr>\n                </tbody></table></div>\n              </td>\n            </tr>\n            <tr bgcolor=\"#EDEDED\">\n              <td colspan=\"2\" align=\"center\">\n                <table width=\"550px\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                  <tbody><tr><td valign=\"middle\" align=\"right\" width=\"430px\" style=\"border:0px;margin:0px;padding:0px;\">Buy tickets by phoning the M-u-s-i-c line ---- get your tickets now!:&nbsp;</td>\n                  <td valign=\"middle\" align=\"left\" width=\"120px\" style=\"border:0px;margin:0px;padding:0px;\"><div><img src=\"./img/telefon_lightgrey_bg.gif\" alt=\"music line phone number\" border=\"0\" valign=\"absmiddle\"></div></td>\n                </tr></tbody></table>\n              </td>\n            </tr>\n          </tbody></table>\n          <p>&nbsp;</p>\n          <table width=\"600px\">\n            <tbody><tr align=\"left\">\n              <th style=\"padding-bottom:10px;\"><img src=\"./img/headline_ticket_prices.gif\" border=\"0\"></th>\n            </tr>\n          </tbody></table>\n          <div></div>\n          <table width=\"600px\" cellspacing=\"0\" class=\"prices\">\n            <tbody><tr bgcolor=\"#A9B8BF\">\n              <td><b><font color=\"41545D\">ADULT</font></b></td>\n              <td><b><font color=\"41545D\">FS</font></b></td>\n              <td><b><font color=\"41545D\">RS</font></b></td>\n              <td><b><font color=\"41545D\">DC</font></b></td>\n              <td><b><font color=\"41545D\">ST</font></b></td>\n            </tr>\n            <tr>\n              <td><b><font color=\"41545D\">Obelisks - Monkey, Monkey</font></b></td>\n              <td><font color=\"41545D\">$20.90</font></td>\n              <td><font color=\"41545D\">$20.90</font></td>\n              <td><font color=\"41545D\">$20.90</font></td>\n              <td><font color=\"41545D\">$20.90</font></td>\n        