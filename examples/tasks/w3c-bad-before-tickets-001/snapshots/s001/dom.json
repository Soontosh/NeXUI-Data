  "title": "Welcome to CityLights! [Inaccessible Tickets Page]",
  "html": "<html><head>\n<title>Welcome to CityLights! [Inaccessible Tickets Page]</title>    <style>\n      td {\n        color: #000000;\n        text-decoration: none;\n        font: 15px/15px \"Times New Roman\", Times, serif;\n      }\n      #main .headline {\n        color: #41545d;\n        font: 24px verdana;\n        font-family: impact;\n        text-decoration: none;\n      }\n      .prices td {\n        font: 12px/12px \"Times New Roman\", Times, serif;\n      }\n      #terms{\n        font-family: \"Times New Roman\", Times, serif;\n        text-transform:uppercase;\n        font-size: 13px;\n        line-height: 13px;\n        padding:0;\n        margin:0;\n      }\n    </style>\n    <link href=\"../css/meta.css\" rel=\"stylesheet\" type=\"text/css\">\n    <script type=\"text/javascript\" async=\"\" defer=\"\" src=\"//www.w3.org/analytics/piwik/piwik.js\"></script><script type=\"text/javascript\">\n      function ChangeColor(id, colour){\n        document.getElementById(id).style.backgroundColor=colour;\n      }\n      function switchImage(imgName, imgSrc){\n        if (document.images){\n          if (imgSrc != \"none\"){\n              document.images[imgName].src = imgSrc;\n          }\n        }\n      }\n    </script>\n    <noscript><B><FONT COLOR=RED>This page uses scripts!!!</FONT></B></noscript>\n    <script src=\"../js/onload.js\" type=\"text/javascript\"></script>\n  </head>\n  <body text=\"#000000\" bgcolor=\"#D7D7CD\" leftmargin=\"0px\" topmargin=\"0px\" marginwidth=\"0px\" marginheight=\"0px\" link=\"#226C8E\" vlink=\"#226C8E\" alink=\"#226C8E\">\n    <div id=\"meta-header\">\n      <p id=\"skipnav\"><a href=\"#page\" data-nexui-ref=\"e1\">Skip to inaccessible demo page</a></p>\n      <p id=\"logos\"><a href=\"https://www.w3.org/\" title=\"W3C Home\" data-nexui-ref=\"e2\"><img alt=\"W3C logo\" src=\"../img/w3c.png\" height=\"48\" width=\"72\"></a><a href=\"https://www.w3.org/WAI/\" title=\"WAI Home\" data-nexui-ref=\"e3\"><img alt=\"Web Accessibility Initiative (WAI) logo\" src=\"../img/wai.png\" height=\"48\"></a></p>\n      <h1><span class=\"subhead\">Inaccessible Tickets Page</span><span class=\"hidden\"> -</span> Before and After Demonstration</h1>\n      <p class=\"subline\">Improving a Web site using Web Content Accessibility Guidelines (WCAG) 2.0</p>\n      <div id=\"mnav\" class=\"inaccessible\">\n        <ul>\n          <li class=\"first\"><a href=\"../Overview.html\" data-nexui-ref=\"e4\">Overview</a></li>\n          <li class=\"first\"><a href=\"home.html\" data-nexui-ref=\"e5\">Home</a></li>\n          <li><a href=\"news.html\" data-nexui-ref=\"e6\">News</a></li>\n          <li class=\"current\"><span class=\"hidden\">Current location: </span>Tickets\n            <div class=\"subnav\"><ul>\n              <li class=\"inaccessible\"><strong>Inaccessible:</strong><a class=\"page current\"><span class=\"hidden\">Inaccessible </span>Tickets Page</a><a href=\"./reports/tickets.html\" class=\"report\" data-nexui-ref=\"e7\"><span class=\"hidden\">Inaccessible Tickets Page </span> Report</a></li>\n              <li class=\"accessible\"><strong>Accessible:</strong><a href=\"../after/tickets.html\" class=\"page\" data-nexui-ref=\"e8\"><span class=\"hidden\">Accessible </span>Tickets Page</a><a href=\"../after/reports/tickets.html\" class=\"report\" data-nexui-ref=\"e9\"><span class=\"hidden\">Accessible Tickets Page </span> Report</a></li>\n            </ul><a href=\"./annotated/tickets.html\" class=\"annotoggle\" data-nexui-ref=\"e10\">Show <br>Annotations</a></div>\n          </li>\n          <li><a href=\"survey.html\" data-nexui-ref=\"e11\">Survey</a></li>\n          <li><a href=\"template.html\" data-nexui-ref=\"e12\">Template</a></li>\n        </ul>\n      </div>\n    </div>\n    <div id=\"page\">\n    <p class=\"skip\" id=\"startcontent\">Demo starts here</p>\n    <table width=\"100%\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"#D7D7CD\"><tbody><tr valign=\"MIDDLE\"><td width=\"100%\" align=\"CENTER\">\n    <table width=\"800px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"WHITE\">\n      <tbody><tr height=\"10px\">\n        <td width=\"10px\" background=\"./img/border_left_top.gif\"><img src=\"./img/border_left_top.gif\" width=\"10px\" height=\"10px\"></td>\n        <td width=\"780px\" background=\"./img/border_top.gif\"><img src=\"./img/border_top.gif\" height=\"10px\"></td>\n        <td width=\"10px\" background=\"./img/border_right_top.gif\"><img src=\"./img/border_right_top.gif\" width=\"10px\" height=\"10px\"></td>\n      </tr>\n      <tr>\n        <td width=\"10px\" background=\"./img/border_left.gif\"><img src=\"./img/border_left.gif\" width=\"10px\"></td>\n        <td width=\"780px\" align=\"CENTER\">\n    <table width=\"780px\" height=\"144px\" border=\"0px\" cellspacing=\"0px\" cellpadding=\"0px\" bgcolor=\"WHITE\">\n      <tbody><tr height=\"86px\">\n        <td width=\"443px\" background=\"./img/top_logo_next.gif\" valign=\"MIDDLE\"><div><a href=\"home.html\" data-nexui-ref=\"e13\"><img src=\"./img/top_logo.gif\" width=\"443px\" height=\"86px\" alt=\"Red dot with a white letter 'C' that symbolizes a moon crescent as well as the sun. This logo is followed by a black banner that says 'CITYLIGHTS' which is the name of this online portal. Finally, the slogan of the portal, 'your access to the city', follows in a turquoise green handwriting style and with a slight slant across the top banner.\"></a></div></td>\n        <td width=\"24px\" valign=\"MIDDLE\"><img src=\"./img/top_logo_next_end.gif\" width=\"24px\" height=\"86px\"></td>\n        <td width=\"128px\" valign=\"MIDDLE\"><img src=\"./img/top_weather.gif\" width=\"128px\" height=\"86px\"></td>\n        <td width=\"22px\" valign=\"MIDDLE\"><img src=\"./img/top_logo_next_start.gif\" width=\"22px\" height=\"86px\"></td>\n        <td width=\"163px\" background=\"./img/top_logo_next.gif\" align=\"CENTER\" valign=\"MIDDLE\">\n          <select onchange=