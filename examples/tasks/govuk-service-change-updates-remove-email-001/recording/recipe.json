      },
      "explanation": "I entered an email address so the initial review page includes the email summary row."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial answers are complete, so I am moving to the check-answers page.",
      "postconditions": [
