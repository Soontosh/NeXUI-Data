  "html": "<html><head>\n<title>Welcome to CityLights! [Inaccessible Home Page]</title>    <style>\n      #main * {\n        color: #000000;\n        font: normal 15px \"Times New Roman\", Times, serif;\n        text-decoration: none;\n      }\n      #main p{\n        margin: 6px 0;\n      }\n      #main a {\n        text-decoration: none;\n        color: #226C8E;\n      }\n      #main .headline {\n        margin-top: 0px;\n        color: #41545d;\n        font: 24px verdana;\n        font-family: impact;\n        text-decoration: none;\n        margin-bottom: 0px;\n      }\n      #main .subheadline {\n        padding:16px 0 6px 0;\n        color: #41545d;\n        font: 20px verdana;\n        font-family: impact;\n        text-decoration: none;\n      }\n      #content * {\n        margin: 0;\n        padding: 0;\n      }\n      #content p{\n        margin: 6px 0;\n      }\n      #content .newsbar {\n        background: #eeeee;\n      }\n      :root #content .newsbar {\n        float: left;\n        width: 100%;\n      }\n      #content .newsheadline img {\n        float: left;\n        padding: 0;\n        margin: 0 5px 15px 0;\n      }\n      #content .newsheadline {\n        width: 135px;\n        margin-right: 5px;\n        background: #ededed;\n        padding-right: 10px;\n        vertical-align: top;\n        display: inline-block;\n      }\n      #content .newsheadline a {\n        color: black;\n        font-weight: bold;\n        background: #ededed;\n      }\n      #content .newsheadline p {\n        font-weight: bold;\n        background: #ededed;\n      }\n      * html #content .newsheadline {\n        width: 138px;\n        display: inline;\n      }\n      :root #content .newsheadline {\n        float: left;\n        width: 128px;\n        display: inline;\n      }\n      #content .image {\n        width: 135px;\n        height: 119px;\n        padding: 0 5px;\n        margin-right: 5px;\n        background: #cccccc;\n        display: inline-block;\n 