{
  "task_id": "govuk-service-check-answers-edit-loop-001",
  "title": "Edit A Previous Answer From Check Answers",
  "goal": "Reach the check-answers page, change the email address, and stop after the summary list shows the updated value instead of the old one.",
  "instruction": "Complete the travel support prototype, then use the check-answers page to change the email address and verify the updated value is shown.",
  "path": "../../../examples/sites/govuk-service-prototype/index.html",
  "source": {
    "site_id": "govuk-service-prototype-local",
    "site_name": "Local GOV.UK Service Prototype",
    "category": "government_pattern",
    "redistribution_class": "redistributable_source"
  },
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "tags": [
    "recorded",
    "service-form",
    "check-answers",
    "edit-loop",
    "harder-task"
  ],
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#/check-answers"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "amina.patel@example.com"
    },
    {
      "type": "text_absent",
      "artifact": "reader_view",
      "value": "old-address@example.com"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Full name",
        "text": "Amina Patel"
      },
      "explanation": "I entered the applicant name to start the service journey."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The name is complete, so I am moving to the next question.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Yes",
        "target_text": "Yes"
      },
      "explanation": "I selected email updates, which reveals the email-address field for this route."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "old-address@example.com"
      },
      "explanation": "I entered an initial email address so it can be edited later from the review page."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial answers are complete, so I am moving to the check-answers page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "link",
        "target_name": "Change email address"
      },
      "explanation": "I followed the change link for the email address, which should return me to the previous question with the earlier answer preserved.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        },
        {
          "type": "field_value_equals",
          "match": {
            "role": "textbox",
            "name": "Email address"
          },
          "value": "old-address@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "amina.patel@example.com"
      },
      "explanation": "I replaced the earlier email address with the corrected value."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The corrected answer is entered, so I am returning to the review page to confirm the summary updated.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "amina.patel@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I updated the email address from the check-answers flow and confirmed the summary now shows the corrected value."
      },
      "explanation": "The check-answers page now shows the updated email address, so I am ending the task."
    }
  ],
  "url": "file:///home/santosh/NeXUI/examples/sites/govuk-service-prototype/index.html"
}
