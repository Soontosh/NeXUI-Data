{
  "url": "file:///home/santosh/NeXUI/examples/sites/govuk-service-prototype/index.html#/updates",
  "title": "Do you want email updates about your application? - Apply for travel support",
  "html": "<html lang=\"en\"><head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Do you want email updates about your application? - Apply for travel support</title>\n    <style>\n      :root {\n        --govuk-blue: #1d70b8;\n        --govuk-black: #0b0c0c;\n        --govuk-text: #0b0c0c;\n        --govuk-border: #b1b4b6;\n        --govuk-error: #d4351c;\n        --govuk-bg: #ffffff;\n        --govuk-panel: #f3f2f1;\n      }\n\n      * {\n        box-sizing: border-box;\n      }\n\n      body {\n        margin: 0;\n        font-family: \"GDS Transport\", Arial, sans-serif;\n        color: var(--govuk-text);\n        background: var(--govuk-bg);\n        line-height: 1.45;\n      }\n\n      a {\n        color: var(--govuk-blue);\n      }\n\n      .phase-banner {\n        background: var(--govuk-panel);\n        padding: 12px 16px;\n        border-bottom: 1px solid var(--govuk-border);\n      }\n\n      .phase-tag {\n        display: inline-block;\n        margin-right: 8px;\n        padding: 4px 8px;\n        background: var(--govuk-blue);\n        color: white;\n        font-size: 0.875rem;\n        font-weight: 700;\n        letter-spacing: 0.02em;\n        text-transform: uppercase;\n      }\n\n      .shell {\n        max-width: 860px;\n        margin: 0 auto;\n        padding: 24px 16px 64px;\n      }\n\n      .back-link {\n        display: inline-block;\n        margin-bottom: 16px;\n      }\n\n      main {\n        max-width: 680px;\n      }\n\n      h1 {\n        margin: 0 0 16px;\n        font-size: 2rem;\n        line-height: 1.15;\n      }\n\n      p,\n      legend,\n      label,\n      .hint,\n      .summary-list dt,\n      .summary-list dd {\n        font-size: 1.125rem;\n      }\n\n      .hint {\n        color: #505a5f;\n        margin-bottom: 8px;\n      }\n\n      .form-group {\n        margin-bottom: 24px;\n      }\n\n      .form-group.error {\n        padding-left: 12px;\n        border-left: 4px solid var(--govuk-error);\n      }\n\n      .error-message {\n        display: block;\n        margin: 8px 0 12px;\n        color: var(--govuk-error);\n        font-weight: 700;\n      }\n\n      .text-input {\n        width: min(32rem, 100%);\n        padding: 10px 12px;\n        border: 2px solid var(--govuk-black);\n        font: inherit;\n      }\n\n      .text-input.error {\n        border-color: var(--govuk-error);\n      }\n\n      fieldset {\n        border: 0;\n        padding: 0;\n        margin: 0;\n      }\n\n      .radios {\n        display: grid;\n        gap: 12px;\n      }\n\n      .radio-item {\n        display: flex;\n        align-items: flex-start;\n        gap: 10px;\n      }\n\n      .button {\n        display: inline-block;\n        margin-top: 8px;\n        padding: 12px 18px;\n        border: 0;\n        background: #00703c;\n        color: white;\n        font: inherit;\n        font-weight: 700;\n        cursor: pointer;\n      }\n\n      .error-summary {\n        margin: 0 0 24px;\n        padding: 16px;\n        border: 4px solid var(--govuk-error);\n      }\n\n      .error-summary h2 {\n        margin-top: 0;\n        margin-bottom: 8px;\n        font-size: 1.5rem;\n      }\n\n      .summary-list {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 24px;\n      }\n\n      .summary-list tr {\n        border-bottom: 1px solid var(--govuk-border);\n      }\n\n      .summary-list th,\n      .summary-list td {\n        padding: 14px 8px 14px 0;\n        text-align: left;\n        vertical-align: top;\n      }\n\n      .summary-list th {\n        width: 40%;\n      }\n\n      .visually-hidden {\n        position: absolute;\n        width: 1px;\n        height: 1px;\n        padding: 0;\n        margin: -1px;\n        overflow: hidden;\n        clip: rect(0, 0, 0, 0);\n        white-space: nowrap;\n        border: 0;\n      }\n\n      .inset-text {\n        margin: 24px 0;\n        padding: 16px;\n        border-left: 8px solid var(--govuk-border);\n        background: var(--govuk-panel);\n      }\n\n      .hidden {\n        display: none;\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"phase-banner\">\n      <span class=\"phase-tag\">Prototype</span>\n      <span>This local service prototype is derived from GOV.UK-style service patterns.</span>\n    </div>\n\n    <div class=\"shell\">\n      <a class=\"back-link\" id=\"back-link\" href=\"#/name\" data-nexui-ref=\"e2\">Back</a>\n\n      <main id=\"main-content\" role=\"main\" tabindex=\"-1\" data-nexui-ref=\"e1\">\n        <div id=\"error-summary\" class=\"error-summary hidden\" role=\"alert\" aria-labelledby=\"error-summary-title\">\n          <h2 id=\"error-summary-title\">There is a problem</h2>\n          <ul id=\"error-list\"></ul>\n        </div>\n\n        <section id=\"page-name\" aria-labelledby=\"name-title\" class=\"hidden\">\n          <h1 id=\"name-title\">What is your full name?</h1>\n          <p class=\"hint\">We use this to prepare your travel support application.</p>\n          <div id=\"name-group\" class=\"form-group\">\n            <label for=\"full-name\">Full name</label>\n            <span id=\"name-error\" class=\"error-message hidden\">Enter your full name</span>\n            <input id=\"full-name\" class=\"text-input\" type=\"text\" autocomplete=\"name\" data-nexui-ref=\"e2\" style=\"\">\n          </div>\n          <button id=\"continue-name\" class=\"button\" type=\"button\" data-nexui-ref=\"e3\">Continue</button>\n        </section>\n\n        <section id=\"page-updates\" class=\"\" aria-labelledby=\"updates-title\">\n          <h1 id=\"updates-title\">Do you want email updates about your application?</h1>\n          <div id=\"updates-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">Do you want email updates about your application?</legend>\n              <span id=\"updates-error\" class=\"error-message hidden\">Select whether you want email updates</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"updates-yes\">\n                  <input id=\"updates-yes\" name=\"updates\" type=\"radio\" value=\"yes\" style=\"\" data-nexui-ref=\"e3\">\n                  <span>Yes</span>\n                </label>\n                <label class=\"radio-item\" for=\"updates-no\">\n                  <input id=\"updates-no\" name=\"updates\" type=\"radio\" value=\"no\" style=\"\" data-nexui-ref=\"e5\">\n                  <span>No</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n\n          <div id=\"email-group\" class=\"form-group\">\n            <label for=\"email-address\">Email address</label>\n            <p class=\"hint\">We will only use this to send status updates.</p>\n            <span id=\"email-error\" class=\"error-message hidden\">Enter your email address</span>\n            <input id=\"email-address\" class=\"text-input\" type=\"email\" autocomplete=\"email\" style=\"\" data-nexui-ref=\"e7\">\n          </div>\n          <button id=\"continue-updates\" class=\"button\" type=\"button\" data-nexui-ref=\"e4\">Continue</button>\n        </section>\n\n        <section id=\"page-check-answers\" class=\"hidden\" aria-labelledby=\"check-answers-title\">\n          <h1 id=\"check-answers-title\">Check your answers before sending your application</h1>\n          <table class=\"summary-list\">\n            <tbody>\n              <tr>\n                <th scope=\"row\">Full name</th>\n                <td id=\"summary-name\">Amina Patel</td>\n                <td>\n                  <a id=\"change-name\" href=\"#/name\" data-nexui-ref=\"e3\">Change<span class=\"visually-hidden\"> full name</span></a>\n                </td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Email updates</th>\n                <td id=\"summary-updates\">Yes</td>\n                <td>\n                  <a id=\"change-updates\" href=\"#/updates\" data-nexui-ref=\"e4\">Change<span class=\"visually-hidden\"> email updates</span></a>\n                </td>\n              </tr>\n              <tr id=\"summary-email-row\" class=\"\">\n                <th scope=\"row\">Email address</th>\n                <td id=\"summary-email\">old-address@example.com</td>\n                <td>\n                  <a id=\"change-email\" href=\"#/updates\" data-nexui-ref=\"e5\">Change<span class=\"visually-hidden\"> email address</span></a>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n\n          <div class=\"inset-text\">\n            Your application is not sent yet. Review the details above before you continue.\n          </div>\n          <button id=\"send-application\" class=\"button\" type=\"button\" data-nexui-ref=\"e6\">Send application</button>\n        </section>\n      </main>\n    </div>\n\n    <script>\n      const state = {\n        fullName: '',\n        wantsUpdates: '',\n        emailAddress: '',\n        returnToCheckAnswers: false,\n        errors: {}\n      };\n\n      const mainContent = document.getElementById('main-content');\n      const backLink = document.getElementById('back-link');\n      const errorSummary = document.getElementById('error-summary');\n      const errorList = document.getElementById('error-list');\n\n      const pages = {\n        name: document.getElementById('page-name'),\n        updates: document.getElementById('page-updates'),\n        checkAnswers: document.getElementById('page-check-answers')\n      };\n\n      const fullNameInput = document.getElementById('full-name');\n      const updatesYes = document.getElementById('updates-yes');\n      const updatesNo = document.getElementById('updates-no');\n      const emailAddressInput = document.getElementById('email-address');\n      const emailGroup = document.getElementById('email-group');\n\n      const nameGroup = document.getElementById('name-group');\n      const updatesGroup = document.getElementById('updates-group');\n      const nameError = document.getElementById('name-error');\n      const updatesError = document.getElementById('updates-error');\n      const emailError = document.getElementById('email-error');\n\n      function currentStep() {\n        const hash = window.location.hash.replace(/^#\\//, '');\n        if (hash === 'updates' || hash === 'check-answers') {\n          return hash;\n        }\n        return 'name';\n      }\n\n      function setStep(step) {\n        window.location.hash = `#/${step}`;\n      }\n\n      function clearErrors() {\n        state.errors = {};\n      }\n\n      function renderErrorSummary() {\n        const entries = Object.entries(state.errors);\n        if (entries.length === 0) {\n          errorSummary.classList.add('hidden');\n          errorList.innerHTML = '';\n          return;\n        }\n\n        errorList.innerHTML = entries\n          .map(([field, message]) => `<li><a href=\"#${field}\">${message}</a></li>`)\n          .join('');\n        errorSummary.classList.remove('hidden');\n      }\n\n      function renderFieldErrors() {\n        const hasNameError = Boolean(state.errors['full-name']);\n        nameGroup.classList.toggle('error', hasNameError);\n        nameError.classList.toggle('hidden', !hasNameError);\n        fullNameInput.classList.toggle('error', hasNameError);\n\n        const hasUpdatesError = Boolean(state.errors.updates);\n        updatesGroup.classList.toggle('error', hasUpdatesError);\n        updatesError.classList.toggle('hidden', !hasUpdatesError);\n\n        const hasEmailError = Boolean(state.errors['email-address']);\n        emailGroup.classList.toggle('error', hasEmailError);\n        emailError.classList.toggle('hidden', !hasEmailError);\n        emailAddressInput.classList.toggle('error', hasEmailError);\n      }\n\n      function renderUpdatesControls() {\n        const wantsUpdates = state.wantsUpdates === 'yes';\n        emailGroup.classList.toggle('hidden', !wantsUpdates);\n      }\n\n      function renderCheckAnswers() {\n        document.getElementById('summary-name').textContent = state.fullName || 'Not provided';\n        document.getElementById('summary-updates').textContent =\n          state.wantsUpdates === 'yes' ? 'Yes' : state.wantsUpdates === 'no' ? 'No' : 'Not provided';\n        document.getElementById('summary-email').textContent = state.emailAddress || 'Not provided';\n        document.getElementById('summary-email-row').classList.toggle('hidden', state.wantsUpdates !== 'yes');\n      }\n\n      function renderBackLink(step) {\n        if (step === 'name') {\n          backLink.classList.add('hidden');\n          backLink.setAttribute('tabindex', '-1');\n          return;\n        }\n\n        backLink.classList.remove('hidden');\n        backLink.removeAttribute('tabindex');\n        if (step === 'updates') {\n          backLink.href = '#/name';\n        } else {\n          backLink.href = '#/updates';\n        }\n      }\n\n      function render() {\n        const step = currentStep();\n        pages.name.classList.toggle('hidden', step !== 'name');\n        pages.updates.classList.toggle('hidden', step !== 'updates');\n        pages.checkAnswers.classList.toggle('hidden', step !== 'check-answers');\n\n        fullNameInput.value = state.fullName;\n        updatesYes.checked = state.wantsUpdates === 'yes';\n        updatesNo.checked = state.wantsUpdates === 'no';\n        emailAddressInput.value = state.emailAddress;\n\n        renderUpdatesControls();\n        renderErrorSummary();\n        renderFieldErrors();\n        renderCheckAnswers();\n        renderBackLink(step);\n\n        const titles = {\n          name: 'What is your full name?',\n          updates: 'Do you want email updates about your application?',\n          'check-answers': 'Check your answers before sending your application'\n        };\n        document.title = `${titles[step]} - Apply for travel support`;\n      }\n\n      function focusMain() {\n        mainContent.focus();\n      }\n\n      function validateName() {\n        clearErrors();\n        state.fullName = fullNameInput.value.trim();\n        if (!state.fullName) {\n          state.errors['full-name'] = 'Enter your full name';\n          return false;\n        }\n        return true;\n      }\n\n      function validateUpdates() {\n        clearErrors();\n        state.wantsUpdates = updatesYes.checked ? 'yes' : updatesNo.checked ? 'no' : '';\n        state.emailAddress = emailAddressInput.value.trim();\n\n        if (!state.wantsUpdates) {\n          state.errors.updates = 'Select whether you want email updates';\n        }\n        if (state.wantsUpdates === 'yes' && !state.emailAddress) {\n          state.errors['email-address'] = 'Enter your email address';\n        }\n\n        return Object.keys(state.errors).length === 0;\n      }\n\n      document.getElementById('continue-name').addEventListener('click', () => {\n        if (!validateName()) {\n          render();\n          focusMain();\n          return;\n        }\n        setStep('updates');\n      });\n\n      document.getElementById('continue-updates').addEventListener('click', () => {\n        if (!validateUpdates()) {\n          render();\n          focusMain();\n          return;\n        }\n        setStep('check-answers');\n      });\n\n      [updatesYes, updatesNo].forEach((input) => {\n        input.addEventListener('change', () => {\n          state.wantsUpdates = updatesYes.checked ? 'yes' : updatesNo.checked ? 'no' : '';\n          if (state.wantsUpdates !== 'yes') {\n            state.emailAddress = '';\n            emailAddressInput.value = '';\n          }\n          renderUpdatesControls();\n        });\n      });\n\n      document.getElementById('change-name').addEventListener('click', (event) => {\n        event.preventDefault();\n        clearErrors();\n        setStep('name');\n      });\n\n      [document.getElementById('change-updates'), document.getElementById('change-email')].forEach((link) => {\n        link.addEventListener('click', (event) => {\n          event.preventDefault();\n          clearErrors();\n          state.returnToCheckAnswers = true;\n          setStep('updates');\n        });\n      });\n\n      document.getElementById('send-application').addEventListener('click', () => {\n        document.title = 'Application sent - Apply for travel support';\n      });\n\n      window.addEventListener('hashchange', () => {\n        if (currentStep() === 'check-answers') {\n          state.returnToCheckAnswers = false;\n        }\n        render();\n        focusMain();\n      });\n\n      render();\n    </script>\n  \n\n</body></html>"
}
