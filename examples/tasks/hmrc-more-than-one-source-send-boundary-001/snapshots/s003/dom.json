{
  "url": "file:///home/santosh/NeXUI/examples/sites/hmrc-income-change-prototype/index.html#/income-source",
  "title": "Report an income change",
  "html": "<html lang=\"en\"><head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Report an income change</title>\n    <style>\n      :root {\n        --hmrc-blue: #005ea5;\n        --hmrc-green: #00703c;\n        --hmrc-text: #0b0c0c;\n        --hmrc-border: #b1b4b6;\n        --hmrc-error: #d4351c;\n        --hmrc-panel: #f3f2f1;\n        --hmrc-inset: #e8f1fa;\n      }\n\n      * {\n        box-sizing: border-box;\n      }\n\n      body {\n        margin: 0;\n        color: var(--hmrc-text);\n        background: #fff;\n        font-family: Arial, sans-serif;\n        line-height: 1.5;\n      }\n\n      a {\n        color: var(--hmrc-blue);\n      }\n\n      .service-banner {\n        padding: 12px 16px;\n        background: var(--hmrc-panel);\n        border-bottom: 1px solid var(--hmrc-border);\n      }\n\n      .service-tag {\n        display: inline-block;\n        margin-right: 8px;\n        padding: 4px 8px;\n        background: var(--hmrc-blue);\n        color: #fff;\n        font-size: 0.875rem;\n        font-weight: 700;\n        text-transform: uppercase;\n      }\n\n      .shell {\n        max-width: 860px;\n        margin: 0 auto;\n        padding: 24px 16px 64px;\n      }\n\n      main {\n        max-width: 700px;\n      }\n\n      .back-link {\n        display: inline-block;\n        margin-bottom: 20px;\n      }\n\n      h1 {\n        margin: 0 0 16px;\n        font-size: 2rem;\n        line-height: 1.15;\n      }\n\n      h2 {\n        margin-top: 0;\n      }\n\n      p,\n      label,\n      legend,\n      .hint,\n      .summary-list td,\n      .summary-list th {\n        font-size: 1.125rem;\n      }\n\n      .hint {\n        margin: 0 0 12px;\n        color: #505a5f;\n      }\n\n      .section {\n        display: none;\n      }\n\n      .section.active {\n        display: block;\n      }\n\n      .form-group {\n        margin-bottom: 24px;\n      }\n\n      .form-group.error {\n        padding-left: 12px;\n        border-left: 4px solid var(--hmrc-error);\n      }\n\n      .error-message {\n        display: block;\n        margin: 8px 0 12px;\n        color: var(--hmrc-error);\n        font-weight: 700;\n      }\n\n      .hidden {\n        display: none;\n      }\n\n      .text-input,\n      .textarea {\n        width: min(32rem, 100%);\n        padding: 10px 12px;\n        border: 2px solid var(--hmrc-text);\n        font: inherit;\n      }\n\n      .textarea {\n        min-height: 9rem;\n      }\n\n      .text-input.error,\n      .textarea.error {\n        border-color: var(--hmrc-error);\n      }\n\n      fieldset {\n        padding: 0;\n        margin: 0;\n        border: 0;\n      }\n\n      .radios {\n        display: grid;\n        gap: 12px;\n      }\n\n      .radio-item {\n        display: flex;\n        gap: 10px;\n        align-items: flex-start;\n      }\n\n      .button {\n        display: inline-block;\n        padding: 12px 18px;\n        border: 0;\n        background: var(--hmrc-green);\n        color: #fff;\n        font: inherit;\n        font-weight: 700;\n        cursor: pointer;\n      }\n\n      .button.secondary {\n        background: var(--hmrc-blue);\n      }\n\n      .inset-text {\n        margin: 20px 0 24px;\n        padding: 16px;\n        border-left: 8px solid var(--hmrc-blue);\n        background: var(--hmrc-inset);\n      }\n\n      .error-summary {\n        margin: 0 0 24px;\n        padding: 16px;\n        border: 4px solid var(--hmrc-error);\n      }\n\n      .error-summary h2 {\n        margin-bottom: 8px;\n        font-size: 1.5rem;\n      }\n\n      .summary-list {\n        width: 100%;\n        margin-bottom: 24px;\n        border-collapse: collapse;\n      }\n\n      .summary-list tr {\n        border-bottom: 1px solid var(--hmrc-border);\n      }\n\n      .summary-list th,\n      .summary-list td {\n        padding: 14px 8px 14px 0;\n        text-align: left;\n        vertical-align: top;\n      }\n\n      .summary-list th {\n        width: 32%;\n      }\n\n      .visually-hidden {\n        position: absolute;\n        width: 1px;\n        height: 1px;\n        padding: 0;\n        margin: -1px;\n        overflow: hidden;\n        clip: rect(0, 0, 0, 0);\n        white-space: nowrap;\n        border: 0;\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"service-banner\">\n      <span class=\"service-tag\">Prototype</span>\n      <span>This local fixture is derived from HMRC-style prototype patterns for complex service journeys.</span>\n    </div>\n\n    <div class=\"shell\">\n      <a id=\"back-link\" class=\"back-link\" href=\"#/tax-year\" data-nexui-ref=\"e2\">Back</a>\n\n      <main id=\"main-content\" role=\"main\" tabindex=\"-1\" data-nexui-ref=\"e1\">\n        <div id=\"error-summary\" class=\"error-summary hidden\" role=\"alert\" aria-labelledby=\"error-summary-title\">\n          <h2 id=\"error-summary-title\">There is a problem</h2>\n          <ul id=\"error-list\"></ul>\n        </div>\n\n        <section id=\"page-tax-year\" class=\"section\" aria-labelledby=\"tax-year-title\">\n          <h1 id=\"tax-year-title\">Which tax year are you updating?</h1>\n          <p class=\"hint\">Choose the tax year for the income change you want to report.</p>\n          <div id=\"tax-year-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">Which tax year are you updating?</legend>\n              <span id=\"tax-year-error\" class=\"error-message hidden\">Select a tax year</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"tax-year-2025\">\n                  <input id=\"tax-year-2025\" name=\"tax-year\" type=\"radio\" value=\"2025-26\" data-nexui-ref=\"e2\" style=\"\">\n                  <span>2025 to 2026</span>\n                </label>\n                <label class=\"radio-item\" for=\"tax-year-2024\">\n                  <input id=\"tax-year-2024\" name=\"tax-year\" type=\"radio\" value=\"2024-25\" data-nexui-ref=\"e3\" style=\"\">\n                  <span>2024 to 2025</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <button id=\"continue-tax-year\" class=\"button\" type=\"button\" data-nexui-ref=\"e4\">Continue</button>\n        </section>\n\n        <section id=\"page-income-source\" class=\"section active\" aria-labelledby=\"income-source-title\">\n          <h1 id=\"income-source-title\">What income source changed?</h1>\n          <p class=\"hint\">This helps us ask the right follow-up questions.</p>\n          <div id=\"income-source-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">What income source changed?</legend>\n              <span id=\"income-source-error\" class=\"error-message hidden\">Select the income source that changed</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"source-employed\">\n                  <input id=\"source-employed\" name=\"income-source\" type=\"radio\" value=\"Employment pay\" style=\"\" data-nexui-ref=\"e3\">\n                  <span>Employment pay</span>\n                </label>\n                <label class=\"radio-item\" for=\"source-self-employed\">\n                  <input id=\"source-self-employed\" name=\"income-source\" type=\"radio\" value=\"Self-employment\" style=\"\" data-nexui-ref=\"e4\">\n                  <span>Self-employment</span>\n                </label>\n                <label class=\"radio-item\" for=\"source-pension\">\n                  <input id=\"source-pension\" name=\"income-source\" type=\"radio\" value=\"Pension\" style=\"\" data-nexui-ref=\"e5\">\n                  <span>Pension</span>\n                </label>\n                <label class=\"radio-item\" for=\"source-more-than-one\">\n                  <input id=\"source-more-than-one\" name=\"income-source\" type=\"radio\" value=\"More than one source\" style=\"\" data-nexui-ref=\"e6\">\n                  <span>More than one source</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <div id=\"income-source-inset\" class=\"inset-text\">\n            You may need to report one change now and come back for the other income source later.\n          </div>\n          <button id=\"continue-income-source\" class=\"button\" type=\"button\" data-nexui-ref=\"e7\">Continue</button>\n        </section>\n\n        <section id=\"page-change-kind\" class=\"section\" aria-labelledby=\"change-kind-title\">\n          <h1 id=\"change-kind-title\">How did the income change?</h1>\n          <p id=\"change-kind-hint\" class=\"hint\">Tell us whether your more than one source went up, went down, or stopped.</p>\n          <div id=\"change-kind-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">How did the income change?</legend>\n              <span id=\"change-kind-error\" class=\"error-message hidden\">Select how the income changed</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"change-increased\">\n                  <input id=\"change-increased\" name=\"change-kind\" type=\"radio\" value=\"Increased\" style=\"\">\n                  <span>It increased</span>\n                </label>\n                <label class=\"radio-item\" for=\"change-decreased\">\n                  <input id=\"change-decreased\" name=\"change-kind\" type=\"radio\" value=\"Decreased\" style=\"\">\n                  <span>It decreased</span>\n                </label>\n                <label class=\"radio-item\" for=\"change-stopped\">\n                  <input id=\"change-stopped\" name=\"change-kind\" type=\"radio\" value=\"Stopped\" style=\"\">\n                  <span>It stopped</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <button id=\"continue-change-kind\" class=\"button\" type=\"button\">Continue</button>\n        </section>\n\n        <section id=\"page-old-amount\" class=\"section\" aria-labelledby=\"old-amount-title\">\n          <h1 id=\"old-amount-title\">What was the previous monthly amount?</h1>\n          <p class=\"hint\">Enter the amount before the change, in pounds.</p>\n          <div id=\"old-amount-group\" class=\"form-group\">\n            <label for=\"old-amount\">Previous monthly amount</label>\n            <span id=\"old-amount-error\" class=\"error-message hidden\">Enter a valid previous monthly amount</span>\n            <input id=\"old-amount\" class=\"text-input\" inputmode=\"decimal\" autocomplete=\"off\" style=\"\">\n          </div>\n          <button id=\"continue-old-amount\" class=\"button\" type=\"button\">Continue</button>\n        </section>\n\n        <section id=\"page-new-amount\" class=\"section\" aria-labelledby=\"new-amount-title\">\n          <h1 id=\"new-amount-title\">What is the new monthly amount?</h1>\n          <p id=\"new-amount-hint\" class=\"hint\">Enter the amount after the change, in pounds.</p>\n          <div id=\"new-amount-group\" class=\"form-group\">\n            <label for=\"new-amount\">New monthly amount</label>\n            <span id=\"new-amount-error\" class=\"error-message hidden\">Enter a valid new monthly amount</span>\n            <input id=\"new-amount\" class=\"text-input\" inputmode=\"decimal\" autocomplete=\"off\" style=\"\">\n          </div>\n          <button id=\"continue-new-amount\" class=\"button\" type=\"button\">Continue</button>\n        </section>\n\n        <section id=\"page-contact-method\" class=\"section\" aria-labelledby=\"contact-method-title\">\n          <h1 id=\"contact-method-title\">How should we contact you if we need more details?</h1>\n          <p class=\"hint\">Choose one method for follow-up questions about this update.</p>\n          <div id=\"contact-method-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">How should we contact you if we need more details?</legend>\n              <span id=\"contact-method-error\" class=\"error-message hidden\">Select a contact method</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"contact-email\">\n                  <input id=\"contact-email\" name=\"contact-method\" type=\"radio\" value=\"Email\" style=\"\">\n                  <span>Email</span>\n                </label>\n                <label class=\"radio-item\" for=\"contact-text\">\n                  <input id=\"contact-text\" name=\"contact-method\" type=\"radio\" value=\"Text message\" style=\"\">\n                  <span>Text message</span>\n                </label>\n                <label class=\"radio-item\" for=\"contact-post\">\n                  <input id=\"contact-post\" name=\"contact-method\" type=\"radio\" value=\"Post\" style=\"\">\n                  <span>Post</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <div id=\"contact-detail-group\" class=\"form-group hidden\">\n            <label id=\"contact-detail-label\" for=\"contact-detail\">Contact detail</label>\n            <p id=\"contact-detail-hint\" class=\"hint\"></p>\n            <span id=\"contact-detail-error\" class=\"error-message hidden\">Enter the required contact detail</span>\n            <input id=\"contact-detail\" class=\"text-input\" autocomplete=\"off\" style=\"\">\n          </div>\n          <button id=\"continue-contact-method\" class=\"button\" type=\"button\">Continue</button>\n        </section>\n\n        <section id=\"page-notes\" class=\"section\" aria-labelledby=\"notes-title\">\n          <h1 id=\"notes-title\">Add anything that would help us understand the change</h1>\n          <p class=\"hint\">This is optional, but it can reduce follow-up questions.</p>\n          <div class=\"inset-text\">\n            For example, you can tell us when the change started or whether you expect it to happen again.\n          </div>\n          <div id=\"notes-group\" class=\"form-group\">\n            <label for=\"supporting-notes\">Supporting notes</label>\n            <textarea id=\"supporting-notes\" class=\"textarea\" style=\"\"></textarea>\n          </div>\n          <button id=\"continue-notes\" class=\"button\" type=\"button\">Continue</button>\n        </section>\n\n        <section id=\"page-check-answers\" class=\"section\" aria-labelledby=\"check-answers-title\">\n          <h1 id=\"check-answers-title\">Check your answers before sending this update</h1>\n          <p class=\"hint\">Make sure the information below matches the change you want to report.</p>\n          <table class=\"summary-list\">\n            <tbody>\n              <tr>\n                <th scope=\"row\">Tax year</th>\n                <td id=\"summary-tax-year\">2025-26</td>\n                <td><a id=\"change-tax-year\" href=\"#/tax-year\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Income source</th>\n                <td id=\"summary-income-source\">More than one source</td>\n                <td><a id=\"change-income-source\" href=\"#/income-source\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Change</th>\n                <td id=\"summary-change-kind\">Not answered</td>\n                <td><a id=\"change-change-kind\" href=\"#/change-kind\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Previous monthly amount</th>\n                <td id=\"summary-old-amount\">Not answered</td>\n                <td><a id=\"change-old-amount\" href=\"#/old-amount\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">New monthly amount</th>\n                <td id=\"summary-new-amount\">Not answered</td>\n                <td><a id=\"change-new-amount\" href=\"#/new-amount\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Contact method</th>\n                <td id=\"summary-contact-method\">Not answered</td>\n                <td><a id=\"change-contact-method\" href=\"#/contact-method\">Change</a></td>\n              </tr>\n              <tr id=\"summary-contact-detail-row\" class=\"hidden\">\n                <th scope=\"row\" id=\"summary-contact-detail-label\">Contact detail</th>\n                <td id=\"summary-contact-detail\">Not answered</td>\n                <td><a id=\"change-contact-detail\" href=\"#/contact-method\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Supporting notes</th>\n                <td id=\"summary-notes\">No supporting notes added</td>\n                <td><a id=\"change-notes\" href=\"#/notes\">Change</a></td>\n              </tr>\n            </tbody>\n          </table>\n          <div id=\"review-guidance\" class=\"inset-text\">\n            Do not send this update unless the new amount and contact details are correct.\n          </div>\n          <button id=\"send-update\" class=\"button secondary\" type=\"button\">Send update</button>\n        </section>\n\n        <section id=\"page-submitted\" class=\"section\" aria-labelledby=\"submitted-title\">\n          <h1 id=\"submitted-title\">Income change submitted</h1>\n          <p>We have recorded the income change and will contact you if we need more details.</p>\n        </section>\n      </main>\n    </div>\n\n    <script>\n      const steps = [\n        \"tax-year\",\n        \"income-source\",\n        \"change-kind\",\n        \"old-amount\",\n        \"new-amount\",\n        \"contact-method\",\n        \"notes\",\n        \"check-answers\",\n        \"submitted\"\n      ];\n\n      const state = {\n        taxYear: \"\",\n        incomeSource: \"\",\n        changeKind: \"\",\n        oldAmount: \"\",\n        newAmount: \"\",\n        contactMethod: \"\",\n        contactDetail: \"\",\n        notes: \"\"\n      };\n\n      function currentRoute() {\n        const route = window.location.hash.replace(/^#\\//, \"\");\n        return steps.includes(route) ? route : \"tax-year\";\n      }\n\n      function showSection(route) {\n        document.querySelectorAll(\".section\").forEach((section) => {\n          section.classList.toggle(\"active\", section.id === `page-${route}`);\n        });\n        updateBackLink(route);\n        renderState(route);\n        clearErrorSummary();\n        const main = document.getElementById(\"main-content\");\n        main.focus();\n      }\n\n      function updateBackLink(route) {\n        const link = document.getElementById(\"back-link\");\n        const index = steps.indexOf(route);\n        if (index <= 0) {\n          link.classList.add(\"hidden\");\n          return;\n        }\n        link.classList.remove(\"hidden\");\n        link.href = `#/${steps[index - 1]}`;\n      }\n\n      function goTo(route) {\n        window.location.hash = `#/${route}`;\n      }\n\n      function renderState(route) {\n        document.getElementById(\"income-source-inset\").classList.toggle(\"hidden\", state.incomeSource !== \"More than one source\");\n        const detailLabel = document.getElementById(\"contact-detail-label\");\n        const detailHint = document.getElementById(\"contact-detail-hint\");\n        const detailGroup = document.getElementById(\"contact-detail-group\");\n        const detailRow = document.getElementById(\"summary-contact-detail-row\");\n        const summaryDetailLabel = document.getElementById(\"summary-contact-detail-label\");\n\n        let label = \"Contact detail\";\n        let hint = \"\";\n        if (state.contactMethod === \"Email\") {\n          label = \"Email address\";\n          hint = \"We will use this address only if we need more details about the update.\";\n        } else if (state.contactMethod === \"Text message\") {\n          label = \"Mobile number\";\n          hint = \"Enter a mobile number we can text during the day.\";\n        } else if (state.contactMethod === \"Post\") {\n          label = \"Postal address\";\n          hint = \"Enter the postal address where you want letters about this update.\";\n        }\n\n        detailLabel.textContent = label;\n        detailHint.textContent = hint;\n        summaryDetailLabel.textContent = label;\n        detailGroup.classList.toggle(\"hidden\", !state.contactMethod);\n        detailRow.classList.toggle(\"hidden\", !state.contactMethod);\n\n        document.getElementById(\"change-kind-hint\").textContent =\n          state.incomeSource\n            ? `Tell us whether your ${state.incomeSource.toLowerCase()} went up, went down, or stopped.`\n            : \"Tell us whether this income went up, went down, or stopped.\";\n\n        document.getElementById(\"new-amount-hint\").textContent =\n          state.changeKind === \"Stopped\"\n            ? \"Enter 0 if the income stopped completely.\"\n            : \"Enter the amount after the change, in pounds.\";\n\n        document.getElementById(\"summary-tax-year\").textContent = state.taxYear || \"Not answered\";\n        document.getElementById(\"summary-income-source\").textContent = state.incomeSource || \"Not answered\";\n        document.getElementById(\"summary-change-kind\").textContent = state.changeKind || \"Not answered\";\n        document.getElementById(\"summary-old-amount\").textContent = state.oldAmount ? `£${state.oldAmount}` : \"Not answered\";\n        document.getElementById(\"summary-new-amount\").textContent = state.newAmount ? `£${state.newAmount}` : \"Not answered\";\n        document.getElementById(\"summary-contact-method\").textContent = state.contactMethod || \"Not answered\";\n        document.getElementById(\"summary-contact-detail\").textContent = state.contactDetail || \"Not answered\";\n        document.getElementById(\"summary-notes\").textContent = state.notes || \"No supporting notes added\";\n\n        if (route === \"check-answers\") {\n          document.title = \"Check your answers before sending this update\";\n        } else if (route === \"submitted\") {\n          document.title = \"Income change submitted\";\n        } else {\n          document.title = \"Report an income change\";\n        }\n      }\n\n      function clearFieldError(prefix, inputId) {\n        document.getElementById(`${prefix}-group`).classList.remove(\"error\");\n        document.getElementById(`${prefix}-error`).classList.add(\"hidden\");\n        if (inputId) {\n          document.getElementById(inputId).classList.remove(\"error\");\n        }\n      }\n\n      function setFieldError(prefix, inputId, message) {\n        document.getElementById(`${prefix}-group`).classList.add(\"error\");\n        const error = document.getElementById(`${prefix}-error`);\n        error.textContent = message;\n        error.classList.remove(\"hidden\");\n        if (inputId) {\n          document.getElementById(inputId).classList.add(\"error\");\n        }\n      }\n\n      function clearErrorSummary() {\n        document.getElementById(\"error-summary\").classList.add(\"hidden\");\n        document.getElementById(\"error-list\").innerHTML = \"\";\n        [\n          [\"tax-year\", null],\n          [\"income-source\", null],\n          [\"change-kind\", null],\n          [\"old-amount\", \"old-amount\"],\n          [\"new-amount\", \"new-amount\"],\n          [\"contact-method\", null],\n          [\"contact-detail\", \"contact-detail\"]\n        ].forEach(([prefix, inputId]) => clearFieldError(prefix, inputId));\n      }\n\n      function showErrors(errors) {\n        const summary = document.getElementById(\"error-summary\");\n        const list = document.getElementById(\"error-list\");\n        list.innerHTML = \"\";\n        errors.forEach((error) => {\n          const item = document.createElement(\"li\");\n          const link = document.createElement(\"a\");\n          link.href = `#${error.href}`;\n          link.textContent = error.message;\n          item.appendChild(link);\n          list.appendChild(item);\n          setFieldError(error.prefix, error.inputId, error.message);\n        });\n        summary.classList.remove(\"hidden\");\n        summary.focus();\n      }\n\n      function requireRadio(name, prefix, message) {\n        const selected = document.querySelector(`input[name=\"${name}\"]:checked`);\n        if (!selected) {\n          return { ok: false, errors: [{ prefix, inputId: null, href: selected ? selected.id : `${prefix}-group`, message }] };\n        }\n        return { ok: true, value: selected.value };\n      }\n\n      function parseAmount(value) {\n        const normalized = String(value || \"\").trim();\n        if (!normalized || Number.isNaN(Number(normalized))) {\n          return null;\n        }\n        return Number(normalized);\n      }\n\n      function validateAndContinue(route) {\n        clearErrorSummary();\n        const errors = [];\n\n        if (route === \"tax-year\") {\n          const result = requireRadio(\"tax-year\", \"tax-year\", \"Select a tax year\");\n          if (!result.ok) {\n            errors.push(...result.errors);\n          } else {\n            state.taxYear = result.value;\n          }\n        }\n\n        if (route === \"income-source\") {\n          const result = requireRadio(\"income-source\", \"income-source\", \"Select the income source that changed\");\n          if (!result.ok) {\n            errors.push(...result.errors);\n          } else {\n            state.incomeSource = result.value;\n          }\n        }\n\n        if (route === \"change-kind\") {\n          const result = requireRadio(\"change-kind\", \"change-kind\", \"Select how the income changed\");\n          if (!result.ok) {\n            errors.push(...result.errors);\n          } else {\n            state.changeKind = result.value;\n          }\n        }\n\n        if (route === \"old-amount\") {\n          const value = document.getElementById(\"old-amount\").value;\n          const amount = parseAmount(value);\n          if (amount === null || amount <= 0) {\n            errors.push({\n              prefix: \"old-amount\",\n              inputId: \"old-amount\",\n              href: \"old-amount\",\n              message: \"Enter a valid previous monthly amount\"\n            });\n          } else {\n            state.oldAmount = amount.toFixed(2);\n          }\n        }\n\n        if (route === \"new-amount\") {\n          const value = document.getElementById(\"new-amount\").value;\n          const amount = parseAmount(value);\n          const oldAmount = parseAmount(state.oldAmount);\n          if (amount === null || amount < 0) {\n            errors.push({\n              prefix: \"new-amount\",\n              inputId: \"new-amount\",\n              href: \"new-amount\",\n              message: \"Enter a valid new monthly amount\"\n            });\n          } else if (state.changeKind === \"Increased\" && oldAmount !== null && amount <= oldAmount) {\n            errors.push({\n              prefix: \"new-amount\",\n              inputId: \"new-amount\",\n              href: \"new-amount\",\n              message: \"New monthly amount must be higher than the previous amount\"\n            });\n          } else if (state.changeKind === \"Decreased\" && oldAmount !== null && amount >= oldAmount) {\n            errors.push({\n              prefix: \"new-amount\",\n              inputId: \"new-amount\",\n              href: \"new-amount\",\n              message: \"New monthly amount must be lower than the previous amount\"\n            });\n          } else if (state.changeKind === \"Stopped\" && amount !== 0) {\n            errors.push({\n              prefix: \"new-amount\",\n              inputId: \"new-amount\",\n              href: \"new-amount\",\n              message: \"Enter 0 if the income stopped\"\n            });\n          } else {\n            state.newAmount = amount.toFixed(2);\n          }\n        }\n\n        if (route === \"contact-method\") {\n          const method = requireRadio(\"contact-method\", \"contact-method\", \"Select a contact method\");\n          if (!method.ok) {\n            errors.push(...method.errors);\n          } else {\n            state.contactMethod = method.value;\n            const detail = document.getElementById(\"contact-detail\").value.trim();\n            if (!detail) {\n              errors.push({\n                prefix: \"contact-detail\",\n                inputId: \"contact-detail\",\n                href: \"contact-detail\",\n                message: state.contactMethod === \"Email\"\n                  ? \"Enter an email address\"\n                  : state.contactMethod === \"Text message\"\n                    ? \"Enter a mobile number\"\n                    : \"Enter a postal address\"\n              });\n            } else if (state.contactMethod === \"Email\" && !detail.includes(\"@\")) {\n              errors.push({\n                prefix: \"contact-detail\",\n                inputId: \"contact-detail\",\n                href: \"contact-detail\",\n                message: \"Enter an email address in the correct format\"\n              });\n            } else if (state.contactMethod === \"Text message\" && detail.replace(/[^0-9]/g, \"\").length < 8) {\n              errors.push({\n                prefix: \"contact-detail\",\n                inputId: \"contact-detail\",\n                href: \"contact-detail\",\n                message: \"Enter a mobile number with at least 8 digits\"\n              });\n            } else {\n              state.contactDetail = detail;\n            }\n          }\n        }\n\n        if (route === \"notes\") {\n          state.notes = document.getElementById(\"supporting-notes\").value.trim();\n        }\n\n        if (errors.length) {\n          showErrors(errors);\n          return;\n        }\n\n        const nextIndex = Math.min(steps.indexOf(route) + 1, steps.length - 1);\n        goTo(steps[nextIndex]);\n      }\n\n      function bindRadios(name, callback) {\n        document.querySelectorAll(`input[name=\"${name}\"]`).forEach((input) => {\n          input.addEventListener(\"change\", () => callback(input.value));\n        });\n      }\n\n      function hydrateInputs() {\n        if (state.taxYear) {\n          const input = document.querySelector(`input[name=\"tax-year\"][value=\"${state.taxYear}\"]`);\n          if (input) input.checked = true;\n        }\n        if (state.incomeSource) {\n          const input = document.querySelector(`input[name=\"income-source\"][value=\"${state.incomeSource}\"]`);\n          if (input) input.checked = true;\n        }\n        if (state.changeKind) {\n          const input = document.querySelector(`input[name=\"change-kind\"][value=\"${state.changeKind}\"]`);\n          if (input) input.checked = true;\n        }\n        if (state.contactMethod) {\n          const input = document.querySelector(`input[name=\"contact-method\"][value=\"${state.contactMethod}\"]`);\n          if (input) input.checked = true;\n        }\n        document.getElementById(\"old-amount\").value = state.oldAmount;\n        document.getElementById(\"new-amount\").value = state.newAmount;\n        document.getElementById(\"contact-detail\").value = state.contactDetail;\n        document.getElementById(\"supporting-notes\").value = state.notes;\n        renderState(currentRoute());\n      }\n\n      document.getElementById(\"continue-tax-year\").addEventListener(\"click\", () => validateAndContinue(\"tax-year\"));\n      document.getElementById(\"continue-income-source\").addEventListener(\"click\", () => validateAndContinue(\"income-source\"));\n      document.getElementById(\"continue-change-kind\").addEventListener(\"click\", () => validateAndContinue(\"change-kind\"));\n      document.getElementById(\"continue-old-amount\").addEventListener(\"click\", () => validateAndContinue(\"old-amount\"));\n      document.getElementById(\"continue-new-amount\").addEventListener(\"click\", () => validateAndContinue(\"new-amount\"));\n      document.getElementById(\"continue-contact-method\").addEventListener(\"click\", () => validateAndContinue(\"contact-method\"));\n      document.getElementById(\"continue-notes\").addEventListener(\"click\", () => validateAndContinue(\"notes\"));\n      document.getElementById(\"send-update\").addEventListener(\"click\", () => goTo(\"submitted\"));\n\n      bindRadios(\"income-source\", (value) => {\n        state.incomeSource = value;\n        renderState(currentRoute());\n      });\n\n      bindRadios(\"contact-method\", (value) => {\n        state.contactMethod = value;\n        renderState(currentRoute());\n      });\n\n      window.addEventListener(\"hashchange\", () => {\n        hydrateInputs();\n        showSection(currentRoute());\n      });\n\n      hydrateInputs();\n      showSection(currentRoute());\n    </script>\n  \n\n</body></html>"
}
