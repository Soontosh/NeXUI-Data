{
  "url": "file:///home/santosh/NeXUI/examples/sites/govuk-benefits-eligibility-prototype/index.html#/income",
  "title": "Check childcare support eligibility",
  "html": "<html lang=\"en\"><head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Check childcare support eligibility</title>\n    <style>\n      :root {\n        --govuk-blue: #1d70b8;\n        --govuk-black: #0b0c0c;\n        --govuk-text: #0b0c0c;\n        --govuk-border: #b1b4b6;\n        --govuk-error: #d4351c;\n        --govuk-bg: #ffffff;\n        --govuk-panel: #f3f2f1;\n      }\n      * { box-sizing: border-box; }\n      body {\n        margin: 0;\n        font-family: Arial, sans-serif;\n        color: var(--govuk-text);\n        background: var(--govuk-bg);\n        line-height: 1.45;\n      }\n      a { color: var(--govuk-blue); }\n      .phase-banner {\n        background: var(--govuk-panel);\n        padding: 12px 16px;\n        border-bottom: 1px solid var(--govuk-border);\n      }\n      .phase-tag {\n        display: inline-block;\n        margin-right: 8px;\n        padding: 4px 8px;\n        background: var(--govuk-blue);\n        color: white;\n        font-size: 0.875rem;\n        font-weight: 700;\n        text-transform: uppercase;\n      }\n      .shell {\n        max-width: 860px;\n        margin: 0 auto;\n        padding: 24px 16px 64px;\n      }\n      .back-link {\n        display: inline-block;\n        margin-bottom: 16px;\n      }\n      main { max-width: 700px; }\n      h1 {\n        margin: 0 0 16px;\n        font-size: 2rem;\n        line-height: 1.15;\n      }\n      p, legend, label, .hint, .summary-list th, .summary-list td {\n        font-size: 1.125rem;\n      }\n      .hint { color: #505a5f; margin-bottom: 8px; }\n      .form-group { margin-bottom: 24px; }\n      .form-group.error { padding-left: 12px; border-left: 4px solid var(--govuk-error); }\n      .error-message {\n        display: block;\n        margin: 8px 0 12px;\n        color: var(--govuk-error);\n        font-weight: 700;\n      }\n      .text-input {\n        width: min(32rem, 100%);\n        padding: 10px 12px;\n        border: 2px solid var(--govuk-black);\n        font: inherit;\n      }\n      .text-input.error { border-color: var(--govuk-error); }\n      fieldset { border: 0; padding: 0; margin: 0; }\n      .radios { display: grid; gap: 12px; }\n      .radio-item { display: flex; align-items: flex-start; gap: 10px; }\n      .button {\n        display: inline-block;\n        margin-top: 8px;\n        padding: 12px 18px;\n        border: 0;\n        background: #00703c;\n        color: white;\n        font: inherit;\n        font-weight: 700;\n        cursor: pointer;\n      }\n      .error-summary {\n        margin: 0 0 24px;\n        padding: 16px;\n        border: 4px solid var(--govuk-error);\n      }\n      .error-summary h2 {\n        margin-top: 0;\n        margin-bottom: 8px;\n        font-size: 1.5rem;\n      }\n      .summary-list {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 24px;\n      }\n      .summary-list tr { border-bottom: 1px solid var(--govuk-border); }\n      .summary-list th, .summary-list td {\n        padding: 14px 8px 14px 0;\n        text-align: left;\n        vertical-align: top;\n      }\n      .summary-list th { width: 38%; }\n      .visually-hidden {\n        position: absolute;\n        width: 1px;\n        height: 1px;\n        padding: 0;\n        margin: -1px;\n        overflow: hidden;\n        clip: rect(0, 0, 0, 0);\n        white-space: nowrap;\n        border: 0;\n      }\n      .inset-text {\n        margin: 24px 0;\n        padding: 16px;\n        border-left: 8px solid var(--govuk-border);\n        background: var(--govuk-panel);\n      }\n      .hidden { display: none; }\n      .page { display: none; }\n      .page.active { display: block; }\n    </style>\n  </head>\n  <body>\n    <div class=\"phase-banner\">\n      <span class=\"phase-tag\">Prototype</span>\n      <span>This local service prototype is derived from GOV.UK-style eligibility and review journeys.</span>\n    </div>\n    <div class=\"shell\">\n      <a class=\"back-link\" id=\"back-link\" href=\"#/work-status\" data-nexui-ref=\"e2\">Back</a>\n      <main id=\"main-content\" role=\"main\" tabindex=\"-1\" data-nexui-ref=\"e1\">\n        <div id=\"error-summary\" class=\"error-summary hidden\" role=\"alert\" aria-labelledby=\"error-summary-title\">\n          <h2 id=\"error-summary-title\">There is a problem</h2>\n          <ul id=\"error-list\"></ul>\n        </div>\n\n        <section id=\"page-residency\" class=\"page\" aria-labelledby=\"residency-title\">\n          <h1 id=\"residency-title\">Do you usually live in the UK?</h1>\n          <p class=\"hint\">You must usually live in the UK to apply for this support.</p>\n          <div id=\"residency-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">Do you usually live in the UK?</legend>\n              <span id=\"residency-error\" class=\"error-message hidden\">Select whether you usually live in the UK</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"residency-yes\">\n                  <input id=\"residency-yes\" name=\"residency\" type=\"radio\" value=\"Yes\" data-nexui-ref=\"e2\" style=\"\">\n                  <span>Yes</span>\n                </label>\n                <label class=\"radio-item\" for=\"residency-no\">\n                  <input id=\"residency-no\" name=\"residency\" type=\"radio\" value=\"No\" data-nexui-ref=\"e3\" style=\"\">\n                  <span>No</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <button id=\"continue-residency\" class=\"button\" type=\"button\" data-nexui-ref=\"e4\">Continue</button>\n        </section>\n\n        <section id=\"page-children\" class=\"page\" aria-labelledby=\"children-title\">\n          <h1 id=\"children-title\">How many children need childcare?</h1>\n          <p class=\"hint\">Choose the closest answer for the children covered by this application.</p>\n          <div id=\"children-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">How many children need childcare?</legend>\n              <span id=\"children-error\" class=\"error-message hidden\">Select how many children need childcare</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"children-one\">\n                  <input id=\"children-one\" name=\"children\" type=\"radio\" value=\"1 child\" style=\"\" data-nexui-ref=\"e3\">\n                  <span>1 child</span>\n                </label>\n                <label class=\"radio-item\" for=\"children-two\">\n                  <input id=\"children-two\" name=\"children\" type=\"radio\" value=\"2 children\" style=\"\" data-nexui-ref=\"e4\">\n                  <span>2 children</span>\n                </label>\n                <label class=\"radio-item\" for=\"children-three\">\n                  <input id=\"children-three\" name=\"children\" type=\"radio\" value=\"3 or more children\" style=\"\" data-nexui-ref=\"e5\">\n                  <span>3 or more children</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <button id=\"continue-children\" class=\"button\" type=\"button\" data-nexui-ref=\"e6\">Continue</button>\n        </section>\n\n        <section id=\"page-work-status\" class=\"page\" aria-labelledby=\"work-status-title\">\n          <h1 id=\"work-status-title\">What best describes your current work status?</h1>\n          <div id=\"work-status-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">What best describes your current work status?</legend>\n              <span id=\"work-status-error\" class=\"error-message hidden\">Select your current work status</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"work-employed\">\n                  <input id=\"work-employed\" name=\"work-status\" type=\"radio\" value=\"Employed\" style=\"\" data-nexui-ref=\"e3\">\n                  <span>Employed</span>\n                </label>\n                <label class=\"radio-item\" for=\"work-self-employed\">\n                  <input id=\"work-self-employed\" name=\"work-status\" type=\"radio\" value=\"Self-employed\" style=\"\" data-nexui-ref=\"e4\">\n                  <span>Self-employed</span>\n                </label>\n                <label class=\"radio-item\" for=\"work-not-working\">\n                  <input id=\"work-not-working\" name=\"work-status\" type=\"radio\" value=\"Not working\" style=\"\" data-nexui-ref=\"e5\">\n                  <span>Not working</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <div id=\"work-status-guidance\" class=\"inset-text hidden\">\n            You may still be eligible if you are about to start work, but you may need to explain your situation before you can submit an application.\n          </div>\n          <button id=\"continue-work-status\" class=\"button\" type=\"button\" data-nexui-ref=\"e6\">Continue</button>\n        </section>\n\n        <section id=\"page-income\" class=\"page active\" aria-labelledby=\"income-title\">\n          <h1 id=\"income-title\">What is your household income before tax each month?</h1>\n          <p class=\"hint\">Enter the amount in pounds. Use an estimate if your income changes from month to month.</p>\n          <div id=\"income-group\" class=\"form-group\">\n            <label for=\"monthly-income\">Monthly income</label>\n            <span id=\"income-error\" class=\"error-message hidden\">Enter a valid monthly income</span>\n            <input id=\"monthly-income\" class=\"text-input\" inputmode=\"decimal\" autocomplete=\"off\" style=\"\" data-nexui-ref=\"e3\">\n          </div>\n          <button id=\"continue-income\" class=\"button\" type=\"button\" data-nexui-ref=\"e4\">Continue</button>\n        </section>\n\n        <section id=\"page-updates\" class=\"page\" aria-labelledby=\"updates-title\">\n          <h1 id=\"updates-title\">Do you want updates about your eligibility check by email?</h1>\n          <div id=\"updates-group\" class=\"form-group\">\n            <fieldset>\n              <legend class=\"visually-hidden\">Do you want updates by email?</legend>\n              <span id=\"updates-error\" class=\"error-message hidden\">Select whether you want email updates</span>\n              <div class=\"radios\">\n                <label class=\"radio-item\" for=\"updates-yes\">\n                  <input id=\"updates-yes\" name=\"updates\" type=\"radio\" value=\"Yes\" style=\"\" data-nexui-ref=\"e3\">\n                  <span>Yes</span>\n                </label>\n                <label class=\"radio-item\" for=\"updates-no\">\n                  <input id=\"updates-no\" name=\"updates\" type=\"radio\" value=\"No\" style=\"\" data-nexui-ref=\"e4\">\n                  <span>No</span>\n                </label>\n              </div>\n            </fieldset>\n          </div>\n          <div id=\"email-group\" class=\"form-group hidden\">\n            <label for=\"email-address\">Email address</label>\n            <p class=\"hint\">We will only use this to send updates about this eligibility check.</p>\n            <span id=\"email-error\" class=\"error-message hidden\">Enter an email address</span>\n            <input id=\"email-address\" class=\"text-input\" type=\"email\" autocomplete=\"email\" style=\"\">\n          </div>\n          <button id=\"continue-updates\" class=\"button\" type=\"button\" data-nexui-ref=\"e5\">Continue</button>\n        </section>\n\n        <section id=\"page-check-answers\" class=\"page\" aria-labelledby=\"check-answers-title\">\n          <h1 id=\"check-answers-title\">Check your answers before continuing</h1>\n          <table class=\"summary-list\">\n            <tbody>\n              <tr>\n                <th scope=\"row\">Usually live in the UK</th>\n                <td id=\"summary-residency\">Yes</td>\n                <td><a id=\"change-residency\" href=\"#/residency\" data-nexui-ref=\"e3\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Children needing childcare</th>\n                <td id=\"summary-children\">3 or more children</td>\n                <td><a id=\"change-children\" href=\"#/children\" data-nexui-ref=\"e4\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Work status</th>\n                <td id=\"summary-work-status\">Employed</td>\n                <td><a id=\"change-work-status\" href=\"#/work-status\" data-nexui-ref=\"e5\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Monthly income</th>\n                <td id=\"summary-income\">£2100.00</td>\n                <td><a id=\"change-income\" href=\"#/income\" data-nexui-ref=\"e6\">Change</a></td>\n              </tr>\n              <tr>\n                <th scope=\"row\">Email updates</th>\n                <td id=\"summary-updates\">No</td>\n                <td><a id=\"change-updates\" href=\"#/updates\" data-nexui-ref=\"e7\">Change</a></td>\n              </tr>\n              <tr id=\"summary-email-row\" class=\"hidden\">\n                <th scope=\"row\">Email address</th>\n                <td id=\"summary-email\">Not answered</td>\n                <td><a id=\"change-email\" href=\"#/updates\">Change</a></td>\n              </tr>\n            </tbody>\n          </table>\n          <div id=\"eligibility-guidance\" class=\"inset-text\">\n            The next step would continue to a fuller eligibility result. Stop and review the details here before moving on.\n          </div>\n          <button id=\"continue-check-answers\" class=\"button\" type=\"button\" data-nexui-ref=\"e8\">Continue to eligibility result</button>\n        </section>\n\n        <section id=\"page-result\" class=\"page\" aria-labelledby=\"result-title\">\n          <h1 id=\"result-title\">Eligibility result</h1>\n          <p id=\"result-text\"></p>\n        </section>\n      </main>\n    </div>\n\n    <script>\n      const steps = [\"residency\", \"children\", \"work-status\", \"income\", \"updates\", \"check-answers\", \"result\"];\n      const state = {\n        residency: \"\",\n        children: \"\",\n        workStatus: \"\",\n        income: \"\",\n        updates: \"\",\n        email: \"\"\n      };\n\n      function currentRoute() {\n        const route = window.location.hash.replace(/^#\\//, \"\");\n        return steps.includes(route) ? route : \"residency\";\n      }\n\n      function goTo(route) {\n        window.location.hash = `#/${route}`;\n      }\n\n      function updateBackLink(route) {\n        const link = document.getElementById(\"back-link\");\n        const index = steps.indexOf(route);\n        if (index <= 0) {\n          link.classList.add(\"hidden\");\n          return;\n        }\n        link.classList.remove(\"hidden\");\n        link.href = `#/${steps[index - 1]}`;\n      }\n\n      function clearErrors() {\n        document.getElementById(\"error-summary\").classList.add(\"hidden\");\n        document.getElementById(\"error-list\").innerHTML = \"\";\n        [[\"residency\", null], [\"children\", null], [\"work-status\", null], [\"income\", \"monthly-income\"], [\"updates\", null], [\"email\", \"email-address\"]].forEach(([prefix, inputId]) => {\n          document.getElementById(`${prefix}-group`).classList.remove(\"error\");\n          document.getElementById(`${prefix}-error`).classList.add(\"hidden\");\n          if (inputId) {\n            document.getElementById(inputId).classList.remove(\"error\");\n          }\n        });\n      }\n\n      function showErrors(errors) {\n        const summary = document.getElementById(\"error-summary\");\n        const list = document.getElementById(\"error-list\");\n        list.innerHTML = \"\";\n        errors.forEach((error) => {\n          const li = document.createElement(\"li\");\n          const a = document.createElement(\"a\");\n          a.href = `#${error.href}`;\n          a.textContent = error.message;\n          li.appendChild(a);\n          list.appendChild(li);\n          document.getElementById(`${error.prefix}-group`).classList.add(\"error\");\n          const node = document.getElementById(`${error.prefix}-error`);\n          node.textContent = error.message;\n          node.classList.remove(\"hidden\");\n          if (error.inputId) {\n            document.getElementById(error.inputId).classList.add(\"error\");\n          }\n        });\n        summary.classList.remove(\"hidden\");\n      }\n\n      function renderState(route) {\n        document.getElementById(\"work-status-guidance\").classList.toggle(\"hidden\", state.workStatus !== \"Not working\");\n        document.getElementById(\"email-group\").classList.toggle(\"hidden\", state.updates !== \"Yes\");\n        document.getElementById(\"summary-email-row\").classList.toggle(\"hidden\", state.updates !== \"Yes\");\n        document.getElementById(\"summary-residency\").textContent = state.residency || \"Not answered\";\n        document.getElementById(\"summary-children\").textContent = state.children || \"Not answered\";\n        document.getElementById(\"summary-work-status\").textContent = state.workStatus || \"Not answered\";\n        document.getElementById(\"summary-income\").textContent = state.income ? `£${state.income}` : \"Not answered\";\n        document.getElementById(\"summary-updates\").textContent = state.updates || \"Not answered\";\n        document.getElementById(\"summary-email\").textContent = state.email || \"Not answered\";\n        if (route === \"result\") {\n          document.getElementById(\"result-text\").textContent =\n            state.residency === \"Yes\" && state.workStatus !== \"Not working\"\n              ? \"You may be able to continue with a full childcare-support application.\"\n              : \"You may need extra checks before a full childcare-support application can continue.\";\n        }\n      }\n\n      function showPage(route) {\n        document.querySelectorAll(\".page\").forEach((page) => {\n          page.classList.toggle(\"active\", page.id === `page-${route}`);\n        });\n        updateBackLink(route);\n        clearErrors();\n        renderState(route);\n        document.getElementById(\"main-content\").focus();\n      }\n\n      function parseMoney(value) {\n        const normalized = String(value || \"\").trim();\n        if (!normalized || Number.isNaN(Number(normalized))) {\n          return null;\n        }\n        return Number(normalized);\n      }\n\n      function requireRadio(name, prefix, message) {\n        const selected = document.querySelector(`input[name=\"${name}\"]:checked`);\n        if (!selected) {\n          return { ok: false, errors: [{ prefix, inputId: null, href: `${prefix}-group`, message }] };\n        }\n        return { ok: true, value: selected.value };\n      }\n\n      function validateAndContinue(route) {\n        clearErrors();\n        const errors = [];\n        if (route === \"residency\") {\n          const result = requireRadio(\"residency\", \"residency\", \"Select whether you usually live in the UK\");\n          if (!result.ok) errors.push(...result.errors);\n          else state.residency = result.value;\n        }\n        if (route === \"children\") {\n          const result = requireRadio(\"children\", \"children\", \"Select how many children need childcare\");\n          if (!result.ok) errors.push(...result.errors);\n          else state.children = result.value;\n        }\n        if (route === \"work-status\") {\n          const result = requireRadio(\"work-status\", \"work-status\", \"Select your current work status\");\n          if (!result.ok) errors.push(...result.errors);\n          else state.workStatus = result.value;\n        }\n        if (route === \"income\") {\n          const amount = parseMoney(document.getElementById(\"monthly-income\").value);\n          if (amount === null || amount < 0) {\n            errors.push({ prefix: \"income\", inputId: \"monthly-income\", href: \"monthly-income\", message: \"Enter a valid monthly income\" });\n          } else {\n            state.income = amount.toFixed(2);\n          }\n        }\n        if (route === \"updates\") {\n          const result = requireRadio(\"updates\", \"updates\", \"Select whether you want email updates\");\n          if (!result.ok) {\n            errors.push(...result.errors);\n          } else {\n            state.updates = result.value;\n            if (state.updates === \"Yes\") {\n              const email = document.getElementById(\"email-address\").value.trim();\n              if (!email) {\n                errors.push({ prefix: \"email\", inputId: \"email-address\", href: \"email-address\", message: \"Enter an email address\" });\n              } else if (!email.includes(\"@\")) {\n                errors.push({ prefix: \"email\", inputId: \"email-address\", href: \"email-address\", message: \"Enter an email address in the correct format\" });\n              } else {\n                state.email = email;\n              }\n            } else {\n              state.email = \"\";\n            }\n          }\n        }\n        if (errors.length) {\n          showErrors(errors);\n          return;\n        }\n        const index = steps.indexOf(route);\n        goTo(steps[Math.min(index + 1, steps.length - 1)]);\n      }\n\n      function hydrateInputs() {\n        if (state.residency) {\n          const radio = document.querySelector(`input[name=\"residency\"][value=\"${state.residency}\"]`);\n          if (radio) radio.checked = true;\n        }\n        if (state.children) {\n          const radio = document.querySelector(`input[name=\"children\"][value=\"${state.children}\"]`);\n          if (radio) radio.checked = true;\n        }\n        if (state.workStatus) {\n          const radio = document.querySelector(`input[name=\"work-status\"][value=\"${state.workStatus}\"]`);\n          if (radio) radio.checked = true;\n        }\n        if (state.updates) {\n          const radio = document.querySelector(`input[name=\"updates\"][value=\"${state.updates}\"]`);\n          if (radio) radio.checked = true;\n        }\n        document.getElementById(\"monthly-income\").value = state.income;\n        document.getElementById(\"email-address\").value = state.email;\n      }\n\n      document.querySelectorAll('input[name=\"work-status\"]').forEach((node) => {\n        node.addEventListener(\"change\", () => {\n          state.workStatus = node.value;\n          renderState(currentRoute());\n        });\n      });\n      document.querySelectorAll('input[name=\"updates\"]').forEach((node) => {\n        node.addEventListener(\"change\", () => {\n          state.updates = node.value;\n          renderState(currentRoute());\n        });\n      });\n\n      document.getElementById(\"continue-residency\").addEventListener(\"click\", () => validateAndContinue(\"residency\"));\n      document.getElementById(\"continue-children\").addEventListener(\"click\", () => validateAndContinue(\"children\"));\n      document.getElementById(\"continue-work-status\").addEventListener(\"click\", () => validateAndContinue(\"work-status\"));\n      document.getElementById(\"continue-income\").addEventListener(\"click\", () => validateAndContinue(\"income\"));\n      document.getElementById(\"continue-updates\").addEventListener(\"click\", () => validateAndContinue(\"updates\"));\n      document.getElementById(\"continue-check-answers\").addEventListener(\"click\", () => goTo(\"result\"));\n\n      window.addEventListener(\"hashchange\", () => {\n        hydrateInputs();\n        showPage(currentRoute());\n      });\n\n      hydrateInputs();\n      showPage(currentRoute());\n    </script>\n  \n\n</body></html>"
}
