      "value": "NExUI Save Verify Customer"
    },
    {
      "type": "trace_note_contains",
      "value": "url contains \"/desk/customer?customer_name=\""
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email",
        "text": "Administrator"
      },
      "explanation": "I entered the seeded ERPNext administrator login."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Password",
        "text": "admin"
      },
      "explanation": "I entered the seeded ERPNext password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Login"
      },
      "explanation": "I signed in so ERPNext can redirect back to a fresh new customer form.",
      "wait_until": "networkidle",
      "post_delay_ms": 2000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer/new-customer-"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "button",
            "name": "Save"
          }
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "input[data-fieldname=\"customer_name\"]",
        "text": "NExUI Save Verify Customer"
      },
      "explanation": "I entered the deterministic customer name."
    },
    {
      "action": {
        "type": "click",
        "target_role": "tab",
        "target_name": "Details"
      },
      "explanation": "I re-focused the details tab so ERPNext commits the typed customer name before saving."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Save"
      },
      "explanation": "I saved the new customer so I can verify it from the customer list.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer/NExUI%20Save%20Verify%20Customer"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "a[href='/desk/customer']"
      },
      "explanation": "I returned to the customer list so I can verify the saved customer from a second view.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "name": "Customer Name"
          }
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
