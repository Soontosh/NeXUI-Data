        "type": "type",
        "target_role": "textbox",
        "target_name": "Customer Name",
        "text": "NExUI Save Verify Customer"
      },
      "explanation": "I entered the saved customer name into the customer-list filter."
    },
    {
      "action": {
        "type": "click",
