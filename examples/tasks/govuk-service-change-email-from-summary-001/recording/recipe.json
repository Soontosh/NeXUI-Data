    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Yes"
      },
      "explanation": "I selected email updates, which reveals the email-address field."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "old-address@example.com"
      },
      "explanation": "I entered the initial email address so the first review page includes an email row."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial answers are complete, so I am moving to the check-answers page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "old-address@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_selector": "#change-email"
      },
      "explanation": "I followed the change link for the email address so I can update that answer.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        },
        {
          "type": "field_value_equals",
          "match": {
