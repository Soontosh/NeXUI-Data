            "name": "Email address"
          },
          "value": "old-address@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "amina.patel@example.com"
      },
      "explanation": "I replaced the original email address with the corrected value."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The corrected email is entered, so I am returning to the review page to verify the updated summary.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
