{
  "task_id": "erpnext-open-seeded-customer-detail-001",
  "title": "Open The Seeded ERPNext Customer Detail Page",
  "goal": "Sign in to ERPNext, filter the customer list to the seeded customer, open that customer record, and stop on the document detail page.",
  "instruction": "Open the ERPNext customer list, sign in as Administrator with password admin, filter Customer Name to NExUI Test Customer, open that customer record, and stop once the seeded customer detail page is visible.",
  "url": "http://localhost:8090/app/customer",
  "source_surface": "erpnext-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 6,
    "cross_view_verification": true,
    "summary_edit_propagation": false,
    "conditional_ui": true,
    "async_or_modal": false,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 1,
  "tags": [
    "recorded",
    "erpnext",
    "authenticated",
    "customer-list",
    "customer-detail",
    "hard"
  ],
  "review_notes": "Fixture-backed ERPNext detail task that opens the seeded customer from the filtered customer list.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/desk/customer/NExUI%20Test%20Customer"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "NExUI Test Customer"
    },
    {
      "type": "candidate_exists",
      "match": {
        "role": "button",
        "name": "Save"
      }
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email",
        "text": "Administrator"
      },
      "explanation": "I entered the seeded ERPNext administrator login."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Password",
        "text": "admin"
      },
      "explanation": "I entered the seeded ERPNext password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Login"
      },
      "explanation": "I signed in so ERPNext can redirect back to the customer list.",
      "wait_until": "networkidle",
      "post_delay_ms": 2000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "name": "Customer Name"
          }
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Customer Name",
        "text": "NExUI Test Customer"
      },
      "explanation": "I entered the seeded customer name into the list filter."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Filter"
      },
      "explanation": "I applied the customer-name filter so the seeded row is isolated.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer?customer_name="
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Test Customer"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "a[href='/desk/customer/NExUI%20Test%20Customer']"
      },
      "explanation": "I opened the seeded customer record from the filtered list.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/customer/NExUI%20Test%20Customer"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Test Customer"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I opened the seeded ERPNext customer record from the filtered customer list."
      },
      "explanation": "The seeded customer detail page is visible now, so I am ending the task."
    }
  ]
}
