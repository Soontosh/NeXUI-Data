  "title": "Citylights Template [Accessible Template Page]",
  "html": "<html lang=\"en\"><head>\n    <title>Citylights Template [Accessible Template Page]</title>\n    <meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\">\n    <link href=\"../css/main.css\" rel=\"stylesheet\" type=\"text/css\">\n    <script type=\"text/javascript\" async=\"\" defer=\"\" src=\"//www.w3.org/analytics/piwik/piwik.js\"></script><script src=\"../js/onload.js\" type=\"text/javascript\"></script>\n    <script src=\"../js/localdate.js\" type=\"text/javascript\"></script>\n  </head>\n  <body>\n    <div id=\"meta-header\">\n      <p id=\"skipnav\"><a href=\"#page\" data-nexui-ref=\"e1\">Skip to accessible demo page</a></p>\n      <p id=\"logos\"><a href=\"https://www.w3.org/\" title=\"W3C Home\" data-nexui-ref=\"e2\"><img alt=\"W3C logo\" src=\"../img/w3c.png\" height=\"48\" width=\"72\"></a><a href=\"https://www.w3.org/WAI/\" title=\"WAI Home\" data-nexui-ref=\"e3\"><img alt=\"Web Accessibility Initiative (WAI) logo\" src=\"../img/wai.png\" height=\"48\"></a></p>\n      <h1><span class=\"subhead\">Accessible Template Page</span><span class=\"hidden\"> -</span> Before and After Demonstration</h1>\n      <p class=\"subline\">Improving a Web site using Web Content Accessibility Guidelines (WCAG) 2.0</p>\n      <div id=\"mnav\" class=\"accessible\">\n        <ul>\n          <li class=\"first\"><a href=\"../Overview.html\" data-nexui-ref=\"e4\">Overview</a></li>\n          <li class=\"first\"><a href=\"home.html\" data-nexui-ref=\"e5\">Home</a></li>\n          <li><a href=\"news.html\" data-nexui-ref=\"e6\">News</a></li>\n          <li><a href=\"tickets.html\" data-nexui-ref=\"e7\">Tickets</a></li>\n          <li><a href=\"survey.html\" data-nexui-ref=\"e8\">Survey</a></li>\n          <li class=\"current\"><span class=\"hidden\">Current location: </span>Template\n            <div class=\"subnav\"><ul>\n              <li class=\"inaccessible\"><strong>Inaccessible:</strong><a href=\"../before/template.html\" class=\"page\" data-nexui-ref=\"e9\"><span class=\"hidden\">Inaccessible </span>Template</a><a href=\"../before/reports/template.html\" class=\"report\" data-nexui-ref=\"e10\"><span class=\"hidden\">Inaccessible Template </span> Report</a></li>\n              <li class=\"accessible\"><strong>Accessible:</strong><a class=\"page current\"><span class=\"hidden\">Accessible </span>Template</a><a href=\"./reports/template.html\" class=\"report\" data-nexui-ref=\"e11\"><span class=\"hidden\">Accessible Template </span> Report</a></li>\n            </ul><a href=\"./annotated/template.html\" class=\"annotoggle\" data-nexui-ref=\"e12\">Show <br>Annotations</a></div>\n          </li>\n        </ul>\n      </div>\n    </div>\n    <div id=\"page\">\n      <div id=\"border_t\"></div>\n      <div id=\"border_l\">\n        <div id=\"border_r\">\n          <p class=\"skip\" id=\"startcontent\">Demo starts here</p>\n          <ul class=\"skip\">\n            <li><a href=\"#content\" data-nexui-ref=\"e13\">Skip to content (within demo page)</a></li>\n            <li><a href=\"#navtarget\" data-nexui-ref=\"e14\">Skip to navigation (within demo page)</a></li>\n          </ul><!--// START HEADER AREA //-->\n          <div id=\"header\">\n            <a href=\"home.html\" data-nexui-ref=\"e15\"><img src=\"./img/toplogo.png\" alt=\"Citylights: your access to the city.\"></a><img src=\"./img/weather.png\" alt=\"Sunny Spells\">\n            <form action=\"../offsite.html\" method=\"post\" onsubmit=\"if(qkmenu.value=='0'){return false;}\">\n              <div>\n                <label for=\"qkmenu\" id=\"qklabel\">Explore Site by Topic:</label> <select name=\"qkemnu\" id=\"qkmenu\" data-nexui-ref=\"e16\">\n                  <option value=\"0\">Quick Menu</option>\n                  <option>Broadcasting</option>\n                  <option>Education</option>\n                  <option>Electricity</option>\n                  <option>Fire service</option>\n                  <option>Gas service</option>\n                  <option>Health care</option>\n                  <option>Police service</option>\n                  <option>Public Libraries</option>\n                  <option>Social services</option>\n                  <option>Social housing</option>\n                  <option>Telecommunications</option>\n                  <option>Town planning</option>\n                  <option>Transportation</option>\n                  <option>Waste management</option>\n                  <option>Water services</option>\n                </select> <input type=\"submit\" value=\"Go\" data-nexui-ref=\"e17\">\n              </div>\n            </form>\n          </div>\n          <div id=\"info\">\n            <p class=\"left\"><strong>Traffic:</strong> Construction work on Main Road</p>\n            <p class=\"right\" id=\"weather\"><strong>Today:</strong><span>&nbsp;Thursday 28 May 2026, Sunny Spells, 23°C</span></p>\n          </div>\n          <div id=\"main\">\n            <h2 id=\"navtarget\" class=\"skip\">Navigation menu:</h2>\n            <div id=\"nav\">\n              <ul>\n                <li class=\"home_set\"><a>Home</a></li>\n                <li class=\"news\"><a href=\"news.html\" data-nexui-ref=\"e18\">News</a></li>\n                <li class=\"facts\"><a href=\"tickets.html\" data-nexui-ref=\"e19\">Tickets</a></li>\n                <li class=\"survey \"><a href=\"survey.html\" data-nexui-ref=\"e20\">Survey</a></li>\n              </ul>\n            </div>\n            <div id=\"content\">\n              <div id=\"contentmain\">\n                <h1>Template</h1>\n                <p>[content here]</p>\n              </div>\n              <div id=\"contentright\">\n                <h2>[Title]</h2>\n                <img src=\"./img/teaser_empty.png\" alt=\"\">\n                <p class=\"spacebelow\">[INTRO] <a href=\"#\" class=\"more\" data-nexui-ref=\"e21\">[DESC] - read more</a></p>\n                <h2>[Title]</h2>\n                <img src=\"./img/teaser_empty.png\" alt=\"\">\n      