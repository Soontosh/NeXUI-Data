 find out more, disable this feature or enter your email address to get notified via email if a new update arrives. This message will disappear once you clicked it.\n                            </a>\n                        </div>\n                    \n                    \n                        <div class=\"alert alert-legal\">\n                            <a href=\"/control/global/license/\" data-nexui-ref=\"e14\">\n                                Click here to do a license compliance check to make sure your usage of pretix is in line with pretix' license.\n                            </a>\n                        </div>\n                    \n                    \n                        <div class=\"alert alert-warning\">\n                            The cronjob component of pretix was not executed in the last hours. Please check that you have completed all installation steps and your cronjob is executed correctly.\n                        </div>\n                    \n\n                    \n\n                    \n\n                    \n    <h1>Events</h1>\n    <p>The list below shows all events you have administrative access to. Click on the event name to access event details.</p>\n    \n        <div class=\"panel panel-default\">\n            <div class=\"panel-heading\">\n                <h3 class=\"panel-title\">Filter</h3>\n            </div>\n            <form class=\"panel-body filter-form\" action=\"\" method=\"get\">\n                <div class=\"row\">\n                    <div class=\"col-md-3 col-sm-6 col-xs-12\">\n                        <div class=\"form-group\"><label class=\"control-label\" for=\"id_query\">Event name</label><input type=\"text\" name=\"query\" class=\"form-control\" title=\"\" id=\"id_query\" data-nexui-ref=\"e15\"></div>\n                    </div>\n                    <div class=\"col-md-3 col-sm-6 col-xs-12\">\n                        <div class=\"form-group\"><label class=\"control-label\" for=\"id_status\">Status</label><select name=\"status\" class=\"form-control\" title=\"\" id=\"id_status\" data-nexui-ref=\"e16\">\n  <option value=\"\" selected=\"\">All events</option>\n\n  <option value=\"live\">Shop live</option>\n\n  <option value=\"running\">Shop live and presale running</option>\n\n  <option value=\"notlive\">Shop not live</option>\n\n  <option value=\"future\">Presale not started</option>\n\n  <option value=\"past\">Presale over</option>\n\n  <option value=\"date_future\">Single event running or in the future</option>\n\n  <option value=\"date_past\">Single event in the past</option>\n\n  <option value=\"series\">Event series</option>\n\n</select></div>\n                    </div>\n                    <div class=\"col-md-3 col-sm-6 col-xs-12\">\n                        <div class=\"form-group\"><label class=\"control-label\" for=\"id_date_from\">Date from</label><input type=\"text\" name=\"date_from\" class=\"form-control datepickerfield\" autocomplete=\"off\" placeholder=\"2000-12-31\" title=\"\" id=\"id_date_from\" data-nexui-ref=\"e17\"></div>\n                    </div>\n                    <div class=\"col-md-3 col-sm-6 col-xs-12\">\n                        <div class=\"form-group\"><label class=\"control-label\" for=\"id_date_until\">Date until</label><input type=\"text\" name=\"date_until\" class=\"form-control datepickerfield\" autocomplete=\"off\" placeholder=\"2000-12-31\" title=\"\" id=\"id_date_until\" data-nexui-ref=\"e18\"></div>\n                    </div>\n                    <div class=\"col-md-3 col-sm-6 col-xs-12\">\n                        <div class=\"form-group\"><label class=\"control-label\" for=\"id_organizer\">Organizer</label><select name=\"organizer\" data-model-select2=\"generic\" data-select2-url=\"/control/organizers/select2\" data-placeholder=\"All organizers\" class=\"form-control select2-hidden-accessible\" title=\"\" id=\"id_organizer\" data-select2-id=\"select2-data-id_organizer\" tabindex=\"-1\" aria-hidden=\"true\" data-nexui-ref=\"e