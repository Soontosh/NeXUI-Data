n\"></i></a>\n                    <a href=\"?ordering=date_from\" data-nexui-ref=\"e25\"><i class=\"fa fa-caret-up\"></i></a>\n                    /\n                    End date\n                    <a href=\"?ordering=-date_to\" data-nexui-ref=\"e26\"><i class=\"fa fa-caret-down\"></i></a>\n                    <a href=\"?ordering=date_to\" data-nexui-ref=\"e27\"><i class=\"fa fa-caret-up\"></i></a>\n                </th>\n                <th>\n                    Paid tickets per quota\n                </th>\n                <th>\n                    Status\n                    <a href=\"?ordering=-live\" data-nexui-ref=\"e28\"><i class=\"fa fa-caret-down\"></i></a>\n                    <a href=\"?ordering=live\" data-nexui-ref=\"e29\"><i class=\"fa fa-caret-up\"></i></a>\n                </th>\n                <th class=\"text-right flip\">\n                </th>\n            </tr>\n            </thead>\n            <tbody>\n            \n                <tr>\n                    <td class=\"event-name-col\">\n                        <strong><a href=\"/control/event/nexui/nexui-event/\" data-nexui-ref=\"e30\">NExUI Benchmark Event</a></strong>\n                        <br><small>nexui-event</small>\n                        \n                    </td>\n                    \n                    <td>\n                        \n                            \n                                \n                                    <span class=\"fa fa-fw fa-globe text-muted\" data-toggle=\"tooltip\" title=\"\" data-original-title=\"Online shop\"></span>\n                                \n                            \n                        \n                    </td>\n                    <td class=\"event-date-col\">\n                        \n                            2026-06-15 00:00\n                            \n                                –<br>\n                                2026-06-15 23:59\n                            \n                        \n           