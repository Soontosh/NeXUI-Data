r=\"mr\">Mr. <input type=\"radio\" name=\"t\" id=\"mr\" value=\"mr\" title=\"title\" data-nexui-ref=\"e28\"></label> <label for=\"mrs\">Mrs. <input type=\"radio\" name=\"t\" id=\"mrs\" value=\"mrs\" title=\"title\" data-nexui-ref=\"e29\"></label> <label for=\"n\">Name: <input type=\"text\" name=\"n\" id=\"n\" size=\"30\" style=\"margin-left: 0.5em;\" data-nexui-ref=\"e30\"></label></p>\n                    <p id=\"emailinput\" class=\"input\" style=\"width: 16em; float: left; margin-top: 0.5em;\"><label for=\"em\">eMail Address: <br><input type=\"text\" name=\"em\" id=\"em\" size=\"20\" data-nexui-ref=\"e31\"></label></p>\n                    <p id=\"emailvalid\" class=\"input\" style=\"width: 16em; float: left; margin-top: 0.5em;\"><label for=\"ev\">Retype eMail: <br><input type=\"text\" name=\"ev\" id=\"ev\" size=\"20\" data-nexui-ref=\"e32\"></label></p>\n                  </div>\n                </fieldset>\n                <p class=\"input\"><input type=\"submit\" id=\"submit\" value=\"submit\" alt=\"submit\" name=\"submit\" data-nexui-ref=\"e33\"></p>\n                </form>\n                <hr>\n                <h2 id=\"surveyresults\">Last Weeks's Survey Results</h2>\n                <table class=\"qtable\">\n                  <caption>What is your favorite and least favorite organ?</caption>\n                  <thead>\n                    <tr>\n                      <th></th>\n                      <th scope=\"col\">Lung</th>\n                      <th scope=\"col\">Pancreas</th>\n                      <th scope=\"col\">Spleen</th>\n                      <th scope=\"col\">Liver</th>\n                      <th scope=\"col\">Skin</th>\n                      <th scope=\"col\">Brain</th>\n                    </tr>\n                  </thead>\n                  <tbody>\n                    <tr>\n                      <th scope=\"row\">hate it</th>\n                      <td>4</td>\n                      <td>10</td>\n                      <td>4</td>\n          