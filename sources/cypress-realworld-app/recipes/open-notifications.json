  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='signin-username'] input",
        "text": "Heath93"
      },
      "explanation": "I entered the seeded username for the local demo account."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='signin-password'] input",
        "text": "s3cret"
