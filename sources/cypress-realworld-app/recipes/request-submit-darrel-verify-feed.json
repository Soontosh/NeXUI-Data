  "review_notes": "Long-horizon authenticated task that creates a request to Darrel Ortiz and verifies it later from the personal feed.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "http://localhost:3000/personal"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "NExUI Darrel request"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Darrel Ortiz"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "+$24.00"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='signin-username'] input",
        "text": "Heath93"
      },
      "explanation": "I entered the seeded username for the local demo account."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='signin-password'] input",
        "text": "s3cret"
      },
      "explanation": "I entered the shared seeded password for the example user."
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='signin-submit']"
      },
      "explanation": "I signed in so the authenticated transaction tools can load.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Account Balance"
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='nav-top-new-transaction']"
      },
      "explanation": "I opened the new transaction wizard from the top navigation.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "http://localhost:3000/transaction/new"
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='user-list-search-input']",
        "text": "Darrel"
      },
      "explanation": "I searched for Darrel Ortiz so the receiver list narrows to the intended person."
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='user-list-item-_XblMqbuoP']"
      },
      "explanation": "I selected Darrel Ortiz as the receiver for the request.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Darrel Ortiz"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "button",
            "name": "Request"
          }
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='transaction-create-amount-input'] input",
        "text": "24"
      },
      "explanation": "I entered the seeded request amount."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "[data-test='transaction-create-description-input'] input",
        "text": "NExUI Darrel request"
      },
      "explanation": "I entered a unique note so the new request can be verified later in the feed."
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='transaction-create-submit-request']"
      },
      "explanation": "I submitted the request for Darrel Ortiz.",
      "postconditions": [
        {
          "type": "candidate_exists",
          "match": {
            "role": "link",
            "name": "Return To Transactions"
          }
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='new-transaction-return-to-transactions']"
      },
      "explanation": "I returned from the transaction wizard to the main transaction feeds so I can verify the new request.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "http://localhost:3000/"
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "[data-test='nav-personal-tab']"
      },
      "explanation": "I switched to the personal feed to verify that the newly created request appears in the signed-in user's feed.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "http://localhost:3000/personal"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Darrel request"
        }
      ],
      "postcondition_timeout_ms": 10000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I signed in, created a request to Darrel Ortiz, returned to the transaction feeds, and verified the new request in the personal feed."
      },
      "explanation": "The newly created request is visible in the personal feed now, so I am ending the task."
    }
  ]
