{
  "task_id": "erpnext-open-supplier-address-contact-tab-001",
  "title": "Open The Seeded ERPNext Supplier Address And Contact Tab",
  "goal": "Sign in to ERPNext, filter the supplier list to the seeded supplier, open that supplier record, and switch to the Address & Contact tab.",
  "instruction": "Open the ERPNext supplier list, sign in as Administrator with password admin, filter Supplier Name to NExUI Test Supplier, open that supplier record, switch to the Address & Contact tab, and stop once the address and contact panel is visible.",
  "url": "http://localhost:8090/app/supplier",
  "source": {
    "site_id": "erpnext-self-hosted",
    "site_name": "ERPNext Self-Hosted",
    "category": "other",
    "redistribution_class": "redistributable_source"
  },
  "source_surface": "erpnext-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 7,
    "cross_view_verification": true,
    "summary_edit_propagation": false,
    "conditional_ui": true,
    "async_or_modal": false,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 1,
  "tags": [
    "recorded",
    "erpnext",
    "authenticated",
    "supplier-detail",
    "address-contact",
    "hard"
  ],
  "review_notes": "Fixture-backed ERPNext task that opens the seeded supplier and switches to the Address & Contact tab.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#contact_and_address_tab"
    },
    {
      "type": "text_present",
      "artifact": "dom",
      "value": "Primary Address and Contact"
    },
    {
      "type": "text_present",
      "artifact": "dom",
      "value": "Supplier Primary Contact"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email",
        "text": "Administrator"
      },
      "explanation": "I entered the seeded ERPNext administrator login."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Password",
        "text": "admin"
      },
      "explanation": "I entered the seeded ERPNext password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Login"
      },
      "explanation": "I signed in so ERPNext can redirect back to the supplier list.",
      "wait_until": "networkidle",
      "post_delay_ms": 2000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/supplier"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "name": "Supplier Name"
          }
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Supplier Name",
        "text": "NExUI Test Supplier"
      },
      "explanation": "I entered the seeded supplier name into the list filter."
    },
    {
      "action": {
        "type": "click",
        "target_selector": ".filter-button"
      },
      "explanation": "I applied the supplier-name filter so the seeded row is isolated.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/supplier?supplier_name="
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Test Supplier"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "a[href='/desk/supplier/NExUI%20Test%20Supplier']"
      },
      "explanation": "I opened the seeded supplier record from the filtered list.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/desk/supplier/NExUI%20Test%20Supplier"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Test Supplier"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_role": "tab",
        "target_name": "Address & Contact"
      },
      "explanation": "I switched to the Address & Contact tab on the seeded supplier record.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#contact_and_address_tab"
        },
        {
          "type": "text_present",
          "artifact": "dom",
          "value": "Primary Address and Contact"
        }
      ],
      "postcondition_timeout_ms": 30000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I opened the seeded supplier and switched to the Address & Contact tab."
      },
      "explanation": "The Address & Contact panel is visible now, so I am ending the task."
    }
  ]
}
