        "target_role": "textbox",
        "target_name": "Monthly income",
        "text": "2100"
      },
      "explanation": "I entered the monthly income for the first pass through the form."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The income is complete, so I am moving to updates.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Yes"
      },
      "explanation": "I started on the email-updates branch so the summary initially includes the email row.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Email address"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "childcare@example.com"
      },
      "explanation": "I entered the updates email address."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial branch is complete, so I am moving to check answers.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "childcare@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_selector": "#change-updates"
      },
      "explanation": "I followed the change link for email updates so I can remove that branch from the summary.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        },
        {
          "type": "field_value_equals",
          "match": {
            "role": "textbox",
            "name": "Email address"
          },
          "value": "childcare@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "No"
      },
      "explanation": "I switched the updates answer to No, which removes the email field from this route."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The branch change is complete, so I am returning to check answers to verify the email row disappeared.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "No"
        },
        {
          "type": "text_absent",
          "artifact": "reader_view",
          "value": "childcare@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I returned to check answers after switching updates to No and the email row is no longer present."
      },
      "explanation": "The summary reflects the no-email branch, so I am ending the task."
    }
  ]
