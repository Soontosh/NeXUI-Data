      "explanation": "I selected one child for the childcare count."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The childcare answer is complete, so I am moving to work status.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/work-status"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Employed"
      },
      "explanation": "I selected Employed as the current work status."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The work status is complete, so I am moving to income.",
