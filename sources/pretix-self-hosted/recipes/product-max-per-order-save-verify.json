  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#tab-0-2-open"
    },
    {
      "type": "text_present",
      "artifact": "dom",
      "value": "Your changes have been saved."
    },
    {
      "type": "candidate_exists",
      "match": {
        "role": "spinbutton",
        "value": "4"
      }
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "#id_email",
        "text": "admin@localhost"
      },
      "explanation": "I entered the seeded Pretix administrator email after landing on the protected product route."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_password",
        "text": "admin"
      },
      "explanation": "I entered the seeded Pretix administrator password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Log in"
      },
      "explanation": "I signed in so Pretix can return to the seeded product detail page.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/event/nexui/nexui-event/items/1/"
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_role": "tab",
        "target_name": "Availability"
      },
      "explanation": "I switched to the Availability tab so the purchase-limit controls become visible.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#tab-0-2-open"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Maximum amount per order"
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_max_per_order",
        "text": "4"
      },
      "explanation": "I entered the deterministic purchase limit."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Save"
      },
      "explanation": "I saved the purchase-limit change so I can verify the persisted value on the same Availability tab.",
      "wait_until": "load",
      "post_delay_ms": 1500,
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "dom",
          "value": "Your changes have been saved."
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "spinbutton",
            "value": "4"
          }
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I saved the Pretix product purchase-limit change and verified the persisted value on the Availability tab."
      },
      "explanation": "The saved maximum amount per order is still visible on the Availability tab now, so I am ending the task."
    }
  ]
