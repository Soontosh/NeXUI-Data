{
  "task_id": "pretix-event-contact-email-save-verify-001",
  "title": "Save A pretix Event Contact Email Edit And Verify It Persists",
  "goal": "Sign in to pretix, open the seeded event settings, save a contact email change, and verify the saved value persists on the settings form.",
  "instruction": "Open the self-hosted pretix seeded event settings page, sign in as admin@localhost with password admin, change Contact address to contact@example.test, save the change, and verify that the saved value still appears on the event settings form.",
  "url": "http://localhost:8100/control/event/nexui/nexui-event/settings/",
  "source": {
    "site_id": "pretix-self-hosted",
    "site_name": "pretix Self-Hosted",
    "category": "other",
    "redistribution_class": "redistributable_source"
  },
  "source_surface": "pretix-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 5,
    "cross_view_verification": false,
    "summary_edit_propagation": false,
    "conditional_ui": false,
    "async_or_modal": false,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 1,
  "requires_source_reset": true,
  "tags": [
    "recorded",
    "pretix",
    "authenticated",
    "mutating",
    "event-settings",
    "hard"
  ],
  "review_notes": "Reset-aware Pretix event-settings mutation that saves and verifies the seeded event contact email.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/control/event/nexui/nexui-event/settings/"
    },
    {
      "type": "text_present",
      "artifact": "dom",
      "value": "Your changes have been saved."
    },
    {
      "type": "candidate_exists",
      "match": {
        "role": "textbox",
        "value": "contact@example.test"
      }
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "#id_email",
        "text": "admin@localhost"
      },
      "explanation": "I entered the seeded Pretix administrator email after landing on the protected event settings route."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_password",
        "text": "admin"
      },
      "explanation": "I entered the seeded Pretix administrator password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Log in"
      },
      "explanation": "I signed in so Pretix can return to the seeded event settings page.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/event/nexui/nexui-event/settings/"
        },
        {
          "type": "text_present",
          "artifact": "dom",
          "value": "Contact address"
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_settings-contact_mail",
        "text": "contact@example.test"
      },
      "explanation": "I changed the seeded event contact email on the settings form."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Save"
      },
      "explanation": "I saved the event contact email change so I can verify the persisted value on the same settings page.",
      "wait_until": "load",
      "post_delay_ms": 1500,
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "dom",
          "value": "Your changes have been saved."
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "value": "contact@example.test"
          }
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I saved the Pretix event contact email change and verified the persisted value on the settings form."
      },
      "explanation": "The saved contact email is still visible on the event settings page now, so I am ending the task."
    }
  ]
}
