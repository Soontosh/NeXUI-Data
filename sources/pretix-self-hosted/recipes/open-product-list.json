{
  "task_id": "pretix-open-product-list-001",
  "title": "Open The Seeded pretix Product List",
  "goal": "Sign in to pretix, open the seeded event products surface, and stop on the products list.",
  "instruction": "Open the self-hosted pretix seeded event dashboard, sign in as admin@localhost with password admin, open the Products section, and stop once the products list is visible.",
  "url": "http://localhost:8100/control/event/nexui/nexui-event/",
  "source": {
    "site_id": "pretix-self-hosted",
    "site_name": "pretix Self-Hosted",
    "category": "other",
    "redistribution_class": "redistributable_source"
  },
  "source_surface": "pretix-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 4,
    "cross_view_verification": true,
    "summary_edit_propagation": false,
    "conditional_ui": false,
    "async_or_modal": false,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 1,
  "tags": [
    "recorded",
    "pretix",
    "authenticated",
    "products-list",
    "hard"
  ],
  "review_notes": "First pretix event-detail-to-products navigation task using the seeded event.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/control/event/nexui/nexui-event/items/"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Create a new product"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Products"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "#id_email",
        "text": "admin@localhost"
      },
      "explanation": "I entered the seeded pretix administrator email after landing on the protected event dashboard."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_password",
        "text": "admin"
      },
      "explanation": "I entered the seeded pretix administrator password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Log in"
      },
      "explanation": "I signed in so pretix can return to the seeded event dashboard.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/event/nexui/nexui-event/"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "link",
            "name": "Go to shop"
          }
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "a[href='/control/event/nexui/nexui-event/items/']"
      },
      "explanation": "I opened the products surface for the seeded event and stopped on the authenticated products list.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/event/nexui/nexui-event/items/"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Create a new product"
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    }
  ]
}
