  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/control/event/nexui/nexui-event/"
    },
    {
      "type": "candidate_exists",
      "match": {
        "role": "link",
        "name": "Go to shop"
      }
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "NExUI Benchmark Event"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "#id_email",
        "text": "admin@localhost"
      },
      "explanation": "I entered the seeded pretix administrator email after landing on the protected events route."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#id_password",
        "text": "admin"
      },
      "explanation": "I entered the seeded pretix administrator password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Log in"
      },
      "explanation": "I signed in so pretix can return to the authenticated events list.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/events/"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "NExUI Benchmark Event"
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "a[href='/control/event/nexui/nexui-event/']"
      },
      "explanation": "I opened the seeded event from the authenticated events list and stopped on its dashboard.",
      "wait_until": "load",
      "post_delay_ms": 1000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/control/event/nexui/nexui-event/"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "link",
            "name": "Go to shop"
          }
        }
      ],
      "postcondition_timeout_ms": 20000,
      "postcondition_poll_interval_ms": 250
    }
  ]
