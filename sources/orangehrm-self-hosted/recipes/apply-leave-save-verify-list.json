{
  "task_id": "orangehrm-apply-leave-save-verify-list-001",
  "title": "Apply Annual Leave And Verify It In My Leave List",
  "goal": "Log in to OrangeHRM, apply a one-day annual leave request, and verify it from the My Leave List view.",
  "instruction": "Sign in to the local OrangeHRM admin account, open Apply Leave, choose Annual Leave, request one day of leave on 2026-06-16 with the comment 'NExUI saved leave request', submit it, and stop once the saved request is visible in My Leave List.",
  "url": "http://localhost:8080/web/index.php/leave/applyLeave",
  "source_surface": "orangehrm-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "very_hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 8,
    "cross_view_verification": true,
    "summary_edit_propagation": false,
    "conditional_ui": true,
    "async_or_modal": true,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 1,
  "requires_source_reset": true,
  "tags": [
    "recorded",
    "enterprise",
    "authenticated",
    "leave",
    "mutating",
    "very_hard"
  ],
  "review_notes": "Reset-aware enterprise leave workflow that applies a leave request and verifies it from a second authenticated leave-list view.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/web/index.php/leave/applyLeave"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "NExUI saved leave request"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"username\"]",
        "text": "nexui_admin"
      },
      "explanation": "I entered the seeded OrangeHRM admin username."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"password\"]",
        "text": "NExUIAdmin!2026"
      },
      "explanation": "I entered the seeded OrangeHRM admin password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Login"
      },
      "explanation": "I signed in and returned directly to the Apply Leave page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/web/index.php/leave/applyLeave"
        }
      ],
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "(//form//div[contains(@class,'oxd-select-text-input')])[1]"
      },
      "explanation": "I opened the leave-type chooser."
    },
    {
      "action": {
        "type": "click",
        "target_selector": "//div[@role='option']//span[normalize-space()='Annual Leave']"
      },
      "explanation": "I selected Annual Leave for this saved request.",
      "post_delay_ms": 1000
    },
    {
      "action": {
        "type": "type",
        "target_selector": "xpath=//label[normalize-space()='From Date']/ancestor::div[contains(@class,'oxd-input-group')]//input[@placeholder='yyyy-mm-dd']",
        "text": "2026-06-16"
      },
      "explanation": "I entered the one-day leave date."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "xpath=//label[normalize-space()='Comments']/ancestor::div[contains(@class,'oxd-input-group')]//textarea",
        "text": "NExUI saved leave request"
      },
      "explanation": "I entered a distinctive comment so the new request can be verified later."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Apply"
      },
      "explanation": "I submitted the leave request so I can verify it from My Leave List.",
      "wait_until": "networkidle",
      "post_delay_ms": 2000,
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/web/index.php/leave/applyLeave"
        }
      ],
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "finish",
        "summary": "I applied a one-day Annual Leave request and verified it from My Leave List."
      },
      "explanation": "The saved leave request is visible in My Leave List now, so I am ending the task."
    }
  ]
}
