{
  "task_id": "orangehrm-add-employee-save-verify-pim-001",
  "title": "Create An OrangeHRM Employee And Verify It In PIM",
  "goal": "Log in to OrangeHRM, create Iris Nolan as a new employee, return to the employee list, and verify the new employee in PIM.",
  "instruction": "Sign in to the local OrangeHRM admin account, create Iris Nolan as a new employee from PIM, return to the employee list, search for Iris, and stop when the new employee is visible in the filtered results.",
  "url": "http://localhost:8080/web/index.php/pim/addEmployee",
  "source_surface": "orangehrm-self-hosted",
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "difficulty_band": "very_hard",
  "difficulty_dimensions": {
    "authentication_required": true,
    "meaningful_action_count": 10,
    "cross_view_verification": true,
    "summary_edit_propagation": false,
    "conditional_ui": false,
    "async_or_modal": true,
    "dense_controls": true,
    "safety_boundary": false
  },
  "split": "dev",
  "stability_runs_passed": 5,
  "requires_source_reset": true,
  "tags": [
    "recorded",
    "enterprise",
    "authenticated",
    "pim",
    "mutating",
    "very_hard"
  ],
  "review_notes": "First reset-aware mutating enterprise task on OrangeHRM PIM.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "/web/index.php/pim/viewEmployeeList"
    },
    {
      "type": "field_value_equals",
      "match": {
        "role": "textbox",
        "name": "Type for hints..."
      },
      "value": "Iris"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Iris Nolan"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"username\"]",
        "text": "nexui_admin"
      },
      "explanation": "I entered the seeded OrangeHRM admin username."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"password\"]",
        "text": "NExUIAdmin!2026"
      },
      "explanation": "I entered the seeded OrangeHRM admin password."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Login"
      },
      "explanation": "I signed in and returned directly to the Add Employee workflow so I can create the new enterprise employee record.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/web/index.php/pim/addEmployee"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "name": "First Name"
          }
        }
      ],
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"firstName\"]",
        "text": "Iris"
      },
      "explanation": "I entered the new employee first name."
    },
    {
      "action": {
        "type": "type",
        "target_selector": "input[name=\"lastName\"]",
        "text": "Nolan"
      },
      "explanation": "I entered the new employee last name."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Save"
      },
      "explanation": "I saved the new employee record so I can verify it from the employee list.",
      "wait_until": "networkidle",
      "post_delay_ms": 2000,
      "postconditions": [
        {
          "type": "candidate_exists",
          "match": {
            "role": "textbox",
            "name": "First Name"
          }
        }
      ],
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_role": "link",
        "target_name": "PIM"
      },
      "explanation": "I returned to the employee list to verify the newly created employee from a second view.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "/web/index.php/pim/viewEmployeeList"
        }
      ],
      "post_delay_ms": 3000,
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "type",
        "target_selector": "(//input[@placeholder=\"Type for hints...\"])[1]",
        "text": "Iris"
      },
      "explanation": "I searched for the new employee by first name so the PIM list is narrowed to the created record.",
      "post_delay_ms": 1500
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Search"
      },
      "explanation": "I applied the employee-name filter and stopped on the filtered PIM results that include the new employee.",
      "postconditions": [
        {
          "type": "field_value_equals",
          "match": {
            "role": "textbox",
            "name": "Type for hints..."
          },
          "value": "Iris"
        }
      ],
      "postcondition_timeout_ms": 15000,
      "postcondition_poll_interval_ms": 250
    }
  ]
}
