    {
      "action": {
        "type": "finish",
        "summary": "I changed the income source from Pension to Employment pay and confirmed the review page now reflects the corrected source while keeping the other details."
      },
      "explanation": "The review page now shows the corrected source and preserved details, so I am ending the task."
