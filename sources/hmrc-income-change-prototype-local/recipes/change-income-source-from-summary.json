{
  "task_id": "hmrc-change-income-source-from-summary-001",
  "title": "Change Income Source From Check Answers",
  "goal": "Reach the review page on the pension route, change the income source to employment pay from the summary, and stop after the updated review page reflects the new source.",
  "instruction": "Complete the income change prototype to the review page, then use the change flow to switch the income source from Pension to Employment pay and verify the summary updates.",
  "path": "../../../examples/sites/hmrc-income-change-prototype/index.html",
  "source": {
    "site_id": "hmrc-income-change-prototype-local",
    "site_name": "Local HMRC Income Change Prototype",
    "category": "government_pattern",
    "redistribution_class": "redistributable_source"
  },
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "tags": [
    "recorded",
    "service-form",
    "hmrc-prototype",
    "check-answers",
    "state-propagation",
    "hard"
  ],
  "review_notes": "Harder summary-edit task that changes an earlier route choice and then carries the user back through the remaining pages with preserved data.",
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#/check-answers"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Employment pay"
    },
    {
      "type": "text_absent",
      "artifact": "reader_view",
      "value": "Income source Pension"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "notes@example.com"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "2025 to 2026"
      },
      "explanation": "I selected the tax year for the update."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The tax year is set, so I am moving to the income source.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/income-source"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Pension"
      },
      "explanation": "I chose pension as the initial income source."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The income source is set, so I am moving to the change type.",
