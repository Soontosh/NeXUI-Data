        {
          "type": "url_contains",
          "value": "#/change-kind"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "It increased"
      },
      "explanation": "I selected an increase for the first pass through the form."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The change type is complete, so I am moving to the previous amount.",
