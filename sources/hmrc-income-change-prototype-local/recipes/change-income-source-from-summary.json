          "type": "url_contains",
          "value": "#/old-amount"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The previous amount remains valid, so I am moving to the new amount.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/new-amount"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The new amount still fits the route, so I am moving to contact details.",
      "postconditions": [
        {
          "type": "url_contains",
