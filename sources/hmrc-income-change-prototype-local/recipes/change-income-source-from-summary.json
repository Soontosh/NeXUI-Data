    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "New monthly amount",
        "text": "1525"
      },
      "explanation": "I entered the increased new monthly amount."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The amount details are complete, so I am moving to contact details.",
