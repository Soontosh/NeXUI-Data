        "type": "type",
        "target_role": "textbox",
        "target_name": "Supporting notes",
        "text": "Two income streams changed this month."
      },
      "explanation": "I added a short note about the multi-source update."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The route is complete, so I am moving to the review page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "More than one source"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I followed the more-than-one-source route, confirmed the guidance appeared, and reached the review page with the selected source and contact details."
      },
      "explanation": "The review page reflects the selected route and contact details, so I am ending the task."
    }
