      "explanation": "I entered the previous monthly amount."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The previous amount is complete, so I am moving to the new amount.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/new-amount"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "New monthly amount",
        "text": "1450"
      },
      "explanation": "I entered the increased new amount."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The new amount is complete, so I am moving to contact details.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/contact-method"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Text message"
      },
      "explanation": "I chose text message as the follow-up contact method.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Mobile number"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_selector": "#contact-detail",
        "text": "07700900123"
      },
      "explanation": "I entered the mobile number for follow-up contact."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The contact details are complete, so I am moving to supporting notes.",
      "postconditions": [
