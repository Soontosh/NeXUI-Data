      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "2025 to 2026"
      },
      "explanation": "I selected the tax year for the update."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The tax year is set, so I am moving to the income source.",
