        {
          "type": "url_contains",
          "value": "#/income-source"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "More than one source"
      },
      "explanation": "I selected the route for multiple income sources.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "You may need to report one change now and come back for the other income source later."
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The guidance is visible, so I am continuing to describe how the income changed.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/change-kind"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "It increased"
      },
      "explanation": "I chose an increase so the later amount should be higher."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
