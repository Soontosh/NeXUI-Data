    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The notes page does not need changes, so I am returning to check answers to verify the new contact details.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Text message"
