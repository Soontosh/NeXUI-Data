    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Mobile number",
        "text": "07123456789"
      },
      "explanation": "I entered the mobile number required by the changed contact method."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The updated contact details are complete, so I am moving through notes back to the review page.",
      "postconditions": [
