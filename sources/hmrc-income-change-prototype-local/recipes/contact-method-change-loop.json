        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Mobile number"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I changed the contact method from email to text message and confirmed the review page now shows the mobile number details."
      },
      "explanation": "The review page reflects the changed contact method and value, so I am ending the task."
