{
  "task_id": "govuk-service-change-updates-add-email-001",
  "title": "Change Updates Preference And Add Email Row",
  "goal": "Reach the check-answers page on the no-email branch, change the updates answer to Yes, add an email address, and stop after the summary shows the new email row.",
  "instruction": "Complete the travel support prototype on the no-email branch, then change the updates answer from the check-answers page so the email row appears with the entered address.",
  "path": "../../../examples/sites/govuk-service-prototype/index.html",
  "source": {
    "site_id": "govuk-service-prototype-local",
    "site_name": "Local GOV.UK Service Prototype",
    "category": "government_pattern",
    "redistribution_class": "redistributable_source"
  },
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "tags": [
    "recorded",
    "service-form",
    "branch-change",
    "check-answers",
    "harder-task"
  ],
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#/check-answers"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Yes"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "changed@example.com"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Email address"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Full name",
        "text": "Amina Patel"
      },
      "explanation": "I entered the applicant name to start the service journey."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The name is complete, so I am moving to the updates question.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "No",
        "target_text": "No"
      },
      "explanation": "I selected no email updates for the initial branch."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial route is complete, so I am moving to the check-answers page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "No"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "link",
        "target_name": "Change email updates"
      },
      "explanation": "I followed the change link for the updates answer so I can switch to the email branch.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Yes",
        "target_text": "Yes"
      },
      "explanation": "I switched the updates answer to Yes, which reveals the email field."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "changed@example.com"
      },
      "explanation": "I entered the new email address required by the changed branch."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The branch changed, so I am returning to the review page to verify the email row appears.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "changed@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I changed the updates answer from No to Yes and confirmed the check-answers page now shows the email row with the new address."
      },
      "explanation": "The check-answers page now reflects the email branch, so I am ending the task."
    }
  ]
}
