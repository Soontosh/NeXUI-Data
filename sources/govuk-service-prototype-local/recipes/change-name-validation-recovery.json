{
  "task_id": "govuk-service-change-name-validation-recovery-001",
  "title": "Recover From A Name Validation Error In The Change Flow",
  "goal": "Reach the check-answers page, use the change-name flow, trigger a missing-name validation error, recover from it, and stop after the updated name appears while the email answer remains intact.",
  "instruction": "Complete the travel support prototype, then change the full name from the check-answers page. If the page rejects a missing name, correct it and continue until the updated summary is visible.",
  "path": "../../../examples/sites/govuk-service-prototype/index.html",
  "source": {
    "site_id": "govuk-service-prototype-local",
    "site_name": "Local GOV.UK Service Prototype",
    "category": "government_pattern",
    "redistribution_class": "redistributable_source"
  },
  "risk_level": "safe",
  "allowed_actions": [
    "click",
    "type",
    "finish"
  ],
  "tags": [
    "recorded",
    "service-form",
    "validation",
    "edit-loop",
    "harder-task"
  ],
  "success_assertions": [
    {
      "type": "url_contains",
      "value": "#/check-answers"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "Amina Khan"
    },
    {
      "type": "text_absent",
      "artifact": "reader_view",
      "value": "Amina Patel"
    },
    {
      "type": "text_present",
      "artifact": "reader_view",
      "value": "amina@example.com"
    }
  ],
  "steps": [
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Full name",
        "text": "Amina Patel"
      },
      "explanation": "I entered the applicant name to start the service journey."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The name is complete, so I am moving to the updates question.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "radio",
        "target_name": "Yes",
        "target_text": "Yes"
      },
      "explanation": "I selected email updates, which reveals the email-address field."
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Email address",
        "text": "amina@example.com"
      },
      "explanation": "I entered the email address for the initial review state."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The initial answers are complete, so I am moving to the check-answers page.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "link",
        "target_name": "Change full name"
      },
      "explanation": "I followed the change link for the full name so I can update that earlier answer.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/name"
        },
        {
          "type": "field_value_equals",
          "match": {
            "role": "textbox",
            "name": "Full name"
          },
          "value": "Amina Patel"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Full name",
        "text": ""
      },
      "explanation": "I cleared the full name so I can verify that the change flow reports the missing-field validation correctly."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The page should now report that the full name is missing.",
      "postconditions": [
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Enter your full name"
        }
      ]
    },
    {
      "action": {
        "type": "type",
        "target_role": "textbox",
        "target_name": "Full name",
        "text": "Amina Khan"
      },
      "explanation": "I entered the corrected full name so the service can continue."
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The corrected name is now present, so I am moving through the remaining question.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/updates"
        },
        {
          "type": "field_value_equals",
          "match": {
            "role": "textbox",
            "name": "Email address"
          },
          "value": "amina@example.com"
        }
      ]
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Continue"
      },
      "explanation": "The later answer is still intact, so I am returning to the review page to confirm the updated name.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "#/check-answers"
        },
        {
          "type": "text_present",
          "artifact": "reader_view",
          "value": "Amina Khan"
        }
      ]
    },
    {
      "action": {
        "type": "finish",
        "summary": "I triggered and recovered from a name validation error in the change flow, then confirmed the updated name on the check-answers page."
      },
      "explanation": "The updated summary is visible and the later email answer remained intact, so I am ending the task."
    }
  ]
}
