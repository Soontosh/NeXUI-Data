        },
        {
          "type": "text_present",
          "value": "Add to cart"
        }
      ],
      "postcondition_timeout_ms": 5000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_role": "link",
        "target_name": "Add to cart"
      },
      "explanation": "I added the monitor to the cart. The site confirms this with a browser alert, which I handled automatically.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "prod.html?idp_=10"
        }
      ],
      "postcondition_timeout_ms": 3000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "click",
        "target_selector": "#cartur"
      },
      "explanation": "I opened the cart and will move to the order dialog without submitting anything.",
      "postconditions": [
        {
          "type": "url_contains",
          "value": "cart.html"
        },
        {
          "type": "candidate_exists",
          "match": {
            "role": "button",
            "name": "Place Order"
          }
        }
      ],
      "postcondition_timeout_ms": 12000,
      "postcondition_poll_interval_ms": 250,
      "post_delay_ms": 5000
    },
    {
      "action": {
        "type": "click",
        "target_role": "button",
        "target_name": "Place Order"
      },
      "explanation": "I opened the order-placement dialog and stopped before the final Purchase action.",
      "postconditions": [
        {
          "type": "candidate_exists",
          "match": {
            "role": "button",
            "name": "Purchase"
          }
        },
        {
          "type": "candidate_exists",
          "match": {
