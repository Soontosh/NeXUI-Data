          }
        }
      ],
      "postcondition_timeout_ms": 5000,
      "postcondition_poll_interval_ms": 250
    },
    {
      "action": {
        "type": "ask_user",
        "question": "The Place Order dialog is open. Clicking Purchase would submit the order. Do you want me to continue?"
      },
      "explanation": "The next action would submit the order, so I am asking for confirmation."
    }
