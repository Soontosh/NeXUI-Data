{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexui.dev/schemas/nexui/recording-recipe.schema.json",
  "title": "NExUI Recording Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "steps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "instruction": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "path": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "http_headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "safe",
        "confirmation_required",
        "forbidden"
      ]
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object"
    },
    "user_profile": {
      "type": "object"
    },
    "safety_rules": {
      "type": "object"
    },
    "explanation_rubric": {
      "$ref": "https://nexui.dev/schemas/nexui/explanation-rubric.schema.json"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "review_notes": {
      "type": "string"
    },
    "difficulty_band": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard",
        "very_hard"
      ]
    },
    "difficulty_dimensions": {
      "$ref": "https://nexui.dev/schemas/nexui/task.schema.json#/properties/difficulty_dimensions"
    },
    "source_surface": {
      "type": "string"
    },
    "split": {
      "type": "string",
      "enum": [
        "dev",
        "validation",
        "test",
        "challenge",
        "unassigned"
      ]
    },
    "stability_runs_passed": {
      "type": "integer",
      "minimum": 0
    },
    "requires_source_reset": {
      "type": "boolean"
    },
    "dialog": {
      "$ref": "#/$defs/dialog_policy"
    },
    "success_assertions": {
      "type": "array",
      "items": {
        "$ref": "https://nexui.dev/schemas/nexui/task.schema.json#/$defs/success_assertion"
      }
    },
    "success_any_of": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "https://nexui.dev/schemas/nexui/task.schema.json#/$defs/success_assertion"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "explanation"
        ],
        "properties": {
          "action": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "click",
                  "type",
                  "press",
                  "select",
                  "focus",
                  "wait",
                  "back",
                  "ask_user",
                  "finish"
                ]
              },
              "target": {
                "type": "string"
              },
              "target_selector": {
                "type": "string"
              },
              "target_role": {
                "type": "string"
              },
              "target_name": {
                "type": "string"
              },
              "target_text": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "option": {
                "type": "string"
              },
              "question": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "duration_ms": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "explanation": {
            "type": "string"
          },
          "justification": {
            "$ref": "https://nexui.dev/schemas/nexui/explanation-justification.schema.json"
          },
          "wait_until": {
            "type": "string",
            "enum": [
              "domcontentloaded",
              "load",
              "networkidle",
              "commit"
            ]
          },
          "post_delay_ms": {
            "type": "integer",
            "minimum": 0
          },
          "postconditions": {
            "type": "array",
            "items": {
              "$ref": "https://nexui.dev/schemas/nexui/task.schema.json#/$defs/success_assertion"
            }
          },
          "postcondition_timeout_ms": {
            "type": "integer",
            "minimum": 0
          },
          "postcondition_poll_interval_ms": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dialog": {
            "$ref": "#/$defs/dialog_policy"
          }
        }
      }
    }
  },
  "$defs": {
    "dialog_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "accept",
            "dismiss"
          ]
        },
        "prompt_text": {
          "type": "string"
        }
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "url"
      ]
    },
    {
      "required": [
        "path"
      ]
    }
  ]
}
