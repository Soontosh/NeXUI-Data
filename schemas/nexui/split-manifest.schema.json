{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexui.dev/schemas/nexui/split-manifest.schema.json",
  "title": "NExUI Split Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "split_id",
    "title",
    "task_ids"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.0"
    },
    "split_id": {
      "type": "string",
      "enum": [
        "dev",
        "validation",
        "test",
        "challenge"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "task_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    }
  }
}
