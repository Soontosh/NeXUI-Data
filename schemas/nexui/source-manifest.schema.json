{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexui.dev/schemas/nexui/source-manifest.schema.json",
  "title": "NExUI Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "site_id",
    "site_name",
    "base_url",
    "source_track",
    "category",
    "hosting_mode",
    "redistribution_class",
    "authoring_status",
    "reset_strategy",
    "determinism_level",
    "capture_defaults",
    "entry_points",
    "onboarding"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.0"
    },
    "site_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "site_name": {
      "type": "string",
      "minLength": 1
    },
    "base_url": {
      "type": "string",
      "format": "uri"
    },
    "source_track": {
      "type": "string",
      "enum": [
        "accessibility_first_demo",
        "ui_automation_demo",
        "service_form_pattern",
        "modern_authenticated_app",
        "enterprise_workflow",
        "sandboxed_benchmark_env",
        "other"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "accessibility_demo",
        "ui_automation_demo",
        "education_demo",
        "finance_demo",
        "hr_demo",
        "ecommerce_demo",
        "government_pattern",
        "health_pattern",
        "other"
      ]
    },
    "hosting_mode": {
      "type": "string",
      "enum": [
        "live_demo",
        "self_hosted",
        "benchmark_env",
        "pattern_proto",
        "local_fixture"
      ]
    },
    "redistribution_class": {
      "type": "string",
      "enum": [
        "redistributable_source",
        "live_only_academic_source",
        "inspiration_only_source",
        "permission_required_source"
      ]
    },
    "authoring_status": {
      "type": "string",
      "enum": [
        "planned",
        "intake",
        "surveyed",
        "recording",
        "validated",
        "published",
        "blocked"
      ]
    },
    "reset_strategy": {
      "type": "string",
      "enum": [
        "none",
        "manual_reset",
        "reseed_command",
        "docker_reset",
        "fixture_reload"
      ]
    },
    "determinism_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "legal_review_status": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "documented",
        "approved",
        "blocked"
      ]
    },
    "reset_verified": {
      "type": "boolean"
    },
    "source_priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auth_type": {
          "type": "string",
          "enum": [
            "none",
            "demo_credentials",
            "seeded_local_account",
            "manual_session",
            "unknown"
          ]
        },
        "credentials_env_vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "task_families": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "difficulty_bands": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "easy",
          "medium",
          "hard",
          "very_hard"
        ]
      },
      "uniqueItems": true
    },
    "onboarding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bootstrap_doc",
        "reset_doc",
        "seed_notes_doc"
      ],
      "properties": {
        "bootstrap_doc": {
          "type": "string"
        },
        "reset_doc": {
          "type": "string"
        },
        "seed_notes_doc": {
          "type": "string"
        },
        "setup_notes": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local_checkout_path": {
          "type": "string"
        },
        "healthcheck_url": {
          "type": "string",
          "format": "uri"
        },
        "bootstrap_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "start_command": {
          "type": "string"
        },
        "reseed_command": {
          "type": "string"
        },
        "readiness_command": {
          "type": "string"
        },
        "runtime_recipe": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "capture_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "browser",
        "wait_until",
        "viewport_width",
        "viewport_height",
        "locale"
      ],
      "properties": {
        "browser": {
          "type": "string",
          "enum": [
            "chromium",
            "firefox",
            "webkit"
          ]
        },
        "wait_until": {
          "type": "string",
          "enum": [
            "domcontentloaded",
            "load",
            "networkidle",
            "commit"
          ]
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 0
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "viewport_width": {
          "type": "integer",
          "minimum": 1
        },
        "viewport_height": {
          "type": "integer",
          "minimum": 1
        },
        "locale": {
          "type": "string"
        },
        "http_headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "entry_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "label"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "path": {
            "type": "string"
          },
          "goal_hint": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "anyOf": [
          {
            "required": [
              "url"
            ]
          },
          {
            "required": [
              "path"
            ]
          }
        ]
      }
    },
    "task_ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idea_id",
          "summary",
          "status"
        ],
        "properties": {
          "idea_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "summary": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "surveyed",
              "recording",
              "validated",
              "rejected"
            ]
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "safe",
              "confirmation_required",
              "forbidden"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
