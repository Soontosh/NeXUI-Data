{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexui.dev/schemas/nexui/action.schema.json",
  "title": "NExUI Action Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "explanation"
  ],
  "properties": {
    "action": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "target"
          ],
          "properties": {
            "type": {
              "const": "click"
            },
            "target": {
              "type": "string",
              "pattern": "^e[0-9]+$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "x",
            "y"
          ],
          "properties": {
            "type": {
              "const": "click_xy"
            },
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "target",
            "text"
          ],
          "properties": {
            "type": {
              "const": "type"
            },
            "target": {
              "type": "string",
              "pattern": "^e[0-9]+$"
            },
            "text": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "key"
          ],
          "properties": {
            "type": {
              "const": "press"
            },
            "key": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "target",
            "option"
          ],
          "properties": {
            "type": {
              "const": "select"
            },
            "target": {
              "type": "string",
              "pattern": "^e[0-9]+$"
            },
            "option": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "direction"
          ],
          "properties": {
            "type": {
              "const": "scroll"
            },
            "direction": {
              "type": "string",
              "enum": [
                "up",
                "down",
                "left",
                "right"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "target"
          ],
          "properties": {
            "type": {
              "const": "focus"
            },
            "target": {
              "type": "string",
              "pattern": "^e[0-9]+$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "back"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "wait"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "question"
          ],
          "properties": {
            "type": {
              "const": "ask_user"
            },
            "question": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "summary"
          ],
          "properties": {
            "type": {
              "const": "finish"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    },
    "justification": {
      "$ref": "https://nexui.dev/schemas/nexui/explanation-justification.schema.json"
    }
  }
}
